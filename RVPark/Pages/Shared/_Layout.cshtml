											<hr>
									</li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/Sites/Index">Sites</a></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/SiteTypes/Index">Site Types</a></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/Photos/Index">Photo Gallery</a></li>
									<li><hr></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/Reservations/Index">Reservations</a></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/Transactions/Index">Transactions</a></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/Fees/Index">Fees</a></li>
									<li><hr></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/Users/Index">Users</a></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/Roles/Index">Roles</a></li>
									<li><hr></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/MilitaryBranches/Index">Military Branches</a></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/MilitaryRanks/Index">Military Ranks</a></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/MilitaryStatuses/Index">Military Statuses</a></li>
									<li><hr></li>
									<li><a class="dropdown-item" asp-area="" asp-page="/Admin/Reports/Index">Generate Reports</a></li>
								</ul>
							</li>
						}

						<!-- Make Reservation - context-aware links -->
