					<h5><i class="fas fa-business-time me-2"></i>Office Hours</h5>
					<ul>
						<li><i class="fas fa-sign-in-alt me-2"></i>Check-in: 12:00 PM</li>
						<li><i class="fas fa-sign-out-alt me-2"></i>Check-out: 11:00 AM</li>
						<li><i class="fas fa-calendar-times me-2"></i>Closed on all holidays</li>
						<li><i class="fas fa-info-circle me-2"></i>After-hours check-in available</li>
					</ul>
				</div>
			</div>

			<!-- Simplified Footer Bottom -->
			<div class="footer-bottom">
				<div class="footer-logo">
					<a asp-page="/About" title="About Our Team and Project">
						About Us
					</a>
					<span>&copy; 2025 - Desert Eagle RV Park - All Rights Reserved</span>
				</div>
				<br>
				<!--Back to top -->
