						<li><i class="fas fa-envelope me-2"></i>deserteaglervnellis@gmail.com</li>
						<li><i class="fas fa-map-marker-alt me-2"></i>4907 Fam Camp Drive, Bldg. 2889</li>
						<li><i class="fas fa-clock me-2"></i>Mon - Sun: 8:30 AM - 5 PM</li>
					</ul>
				</div>

				<!-- Office Hours -->
