@page
@model RVPark.Pages.Admin.Roles.IndexModel
@{
}
<div class="d-flex justify-content-between align-items-center">
            <h1 class="text-secondary">Role List</h1>
            <a asp-page="Upsert" class="btn btn-success"><i class="fas fa-plus"></i> &nbsp; Create New</a>
        </div>
    @* <input type="hidden" id="success">@Model.Success.ToString() *@
    @* <input type="hidden" id="message">@Model.Message *@

<div class="card mb-4">
    <div class="card-header">
        <h5 class="my-2"><i class="fa-solid fa-money-bill"></i> Roles</h5>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-lg-4 col-md-6">
                <input type="text" id="searchRolesInput" class="form-control" placeholder="Search Roles">
            </div>
            <div class="col-lg-4 col-md-6 d-flex gap-2">
                <button id="searchRoleButton" class="btn btn-primary">
                    <i class="fas fa-search"></i> Search
                </button>
                <button id="resetRoleSearch" class="btn btn-danger">
                    Reset
                </button>
            </div>
        </div>
    <table id="roleTable" class="table table-striped table-bordered" style="width:100%">
        <thead>
            <tr>
                <th scope="col">Role</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>

				@* Trying to change this to use ajax more than razor syntax          
           @{
                foreach (var role in Model.RolesObj)
                {
                    <tr>
                        <td>@role.Name</td>
                        <td>
                            <a class="btn btn-success" asp-page="Upsert" asp-route-id="@role.Id.ToString()">Update</a>

                        </td>
                    </tr>
                }
            } *@

        </tbody>
    </table>
</div>
</div>
@section Scripts {
    <script>
        var roleTable;
           $(document).ready(function () {
           roleTable = $('#roleTable').DataTable({
               "ajax": "/api/roles",
               "columns": [
                   { "data": "name" },
                   {
                       "data": "id",
                       "render": function (data, type, row, meta) {
                           return `<a class="btn btn-success" href="/Admin/Roles/Upsert?id=${data}">Update</a>`;
                       }
                   }
			   ],

               "paging": true,
               "ordering": true,
               "info": true,
               "responsive": true,
               "autoWidth": false,
               "searching": true,
               "dom": 'lrtip'
           });

                //search button
                $('#searchRoleButton').on('click', function () {
                    const value = $('#searchRolesInput').val();
                    roleTable.search(value).draw();
                });

                // Reset button
                $('#resetRoleSearch').on('click', function () {
                    $('#searchRoleInput').val('');
                    roleTable.search('').draw();
                });
        });
    </script>
    <script>
        function alertFunc() {
            var success = $("#success").html()
            var message = $("#message").html();
            console.log(success);
            console.log(message);
            if (success == "True") {
                toastr.success(message);
            };

        }
        window.onload = alertFunc();
    </script>
}