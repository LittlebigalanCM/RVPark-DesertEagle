@page
@model RVPark.Pages.Admin.Reports.OccupancyReportsModel
@{
}
<head>
    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<div class="border bg-light container p-3 no-print">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-secondary">Occupancy Report</h2>
        </div>
    </div>
    <br />
    <div class="row mb-4">
        <div class="col-md-8 align-content-center">
            <div class="input-group">
                <div class="ms-3">
                    <label>Start date:</label>
                    <input type="date" id="start" class="form-control" />
                </div>
                <div class="ms-3">
                    <label>End date:</label>
                    <input type="date" id="end" class="form-control" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary ms-3" type="button" id="generateButton">Generate</button>
                <button class="btn btn-primary ms-3" type="button" id="dailyReportButton">Daily Report</button>
                <button class="btn btn-danger ms-3" type="button" id="resetButton">Reset</button>
                <button class="btn btn-success ms-3" type="button" id="showMapButton">Show Campsite Map</button>
            </div>

            <div id="inputValTwo" class="alert-danger mt-3" style="display:none">
                Please enter both start and end dates.
            </div>
            <div id="inputValBig" class="alert-danger mt-3" style="display:none">
                Start date must be before end date.
            </div>
        </div>
    </div>
    <br />
    <div id="table_container" style="display:none">
        <table id="DT_load" class="table table-striped table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Contact</th>
                    <th>Site Number</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Status</th>
                </tr>
            </thead>
        </table>
    </div>
    <!-- Print Option Modal -->
    <div class="modal fade" id="printOptionModal" tabindex="-1" aria-labelledby="printOptionModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="printOptionModalLabel">Select Print Option</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Would you like to print the campsite map in color or black-and-white?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" id="printColorButton">Color</button>
                    <button type="button" class="btn btn-secondary" id="printBWButton">Black & White</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Print Button Container -->
<div id="print-button-container" class="print-button-container" style="display:none;">
    <button class="btn btn-success print-map-button" type="button" id="printMapButton" data-bs-toggle="modal" data-bs-target="#printOptionModal">Print Campsite Map</button>
</div>

<!-- Print Section -->
<div id="print-section" class="print-section" style="display:none;">
    <div class="text-center">
        <h4>RV Park Campsite Availability</h4>
        <p id="print-date"></p>
    </div>
    <div class="map-container">
        <div id="campsite-map-container" class="campsite-map-container">
            <!-- SVG will be inserted here -->
        </div>
    </div>
    <div class="customer-message">
        <h5>Welcome to Our RV Park!</h5>
        <p>Please choose any <strong>green (available)</strong> spot on the map and settle in.</p>
        <p>Visit our office tomorrow or pay online at <strong><a href="https://RVsite.com">RVsite.com</a></strong></p>
        <p><strong>Thank you for choosing our RV Park!</strong></p>
        <p><em>Legend: Green = Available • Red = Unavailable</em></p>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.2/js/dataTables.buttons.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.2/js/buttons.dataTables.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.2/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.2/js/buttons.html5.min.js"></script>
    <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="~/js/occupancyreport.js"></script>
}