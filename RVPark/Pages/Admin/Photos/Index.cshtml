@page
@model RVPark.Pages.Admin.Photos.IndexModel

@{
    ViewData["Title"] = "Photo Gallery";
}

@* -Disable the Site Specific Title Feature- *
    if(Model.Site == null)
    {
        <h1 class="text-secondary">Photo Gallery</h1>
    }
    else
    {
        <h1 class="text-secondary">Photos for Site#@Model.Site.Name</h1>

    }
}  
