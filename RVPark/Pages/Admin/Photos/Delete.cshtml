@page 
@model RVPark.Pages.Admin.Photos.DeleteModel

@{
    ViewData["Title"] = "Delete Photo";
}

<h1>Delete Photo</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this photo?</h3>
    <p>This action cannot be undone.</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5>Photo</h5>
            </div>
            <div class="card-body">
                <img src="@Model.Photo.Name" class="img-fluid" alt="Photo">
            </div>
            <div class="card-footer">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Site:</dt>
                    <dd class="col-sm-9">
                        @(Model.Photo.Site?.Name ?? "Unassigned")
                    </dd>

                    <dt class="col-sm-3">Filename:</dt>
                    <dd class="col-sm-9">
                        @Model.Photo.Name
                    </dd>
                </dl>
            </div>
        </div>

        <form method="post">
            <input type="hidden" asp-for="Photo.Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

