            }
        }

        function revertDisability(reservationId) {
            if (confirm('Revert Disability Documents approval?')) {
                fetch("/api/Reservation/RevertDisability", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ reservationId: reservationId })
                })
                .then(r => r.json())
                .then(() => location.reload());
            }
        }

        function revertPCSOrders(reservationId) {
