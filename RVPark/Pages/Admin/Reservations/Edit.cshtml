@page
@using Microsoft.AspNetCore.Mvc.Rendering
@using Infrastructure.Utilities
@model RVPark.Pages.Admin.Reservations.EditModel
@{
    ViewData["Title"] = "Edit Reservation";
}

<form method="post" id="reservationForm">
    <div class="container">
        <div class="row px-2 mx-2 backgroundWhite border">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="col-12 px-3" style="border-bottom:1px solid #325d88">
                <h2 class="text-primary">Edit Reservation #@Model.Reservation.ReservationId</h2>
            </div>

            <!-- Hidden fields for state -->
            <input type="hidden" asp-for="Reservation.ReservationId" />
            <input type="hidden" asp-for="Reservation.UserId" />
            <input type="hidden" id="originalSiteId" value="@Model.Reservation.SiteId" />
            <input type="hidden" id="originalStartDate" value="@Model.Reservation.StartDate.ToString("yyyy-MM-dd")" />
            <input type="hidden" id="originalEndDate" value="@Model.Reservation.EndDate.ToString("yyyy-MM-dd")" />
            <input type="hidden" asp-for="VehiclePlates" />
            <input id="resStatus" type="hidden" asp-for="Reservation.ReservationStatus" />

            <div class="col-8 pt-3">
                <!-- Customer Information -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label>Customer</label></h5>
                    </div>
                    <div class="col-8">
                        <input class="form-control" readonly value="@Model.CustomerName" id="customer" />
                    </div>
                </div>

                <!-- Dates Section -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label asp-for="Reservation.StartDate">Check-in Date</label></h5>
                    </div>
                    <div class="col-8">
                        <input type="date" class="form-control" asp-for="Reservation.StartDate" id="startDate" />
                        <span class="text-danger" asp-validation-for="Reservation.StartDate"></span>
                    </div>
                </div>

                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label asp-for="Reservation.EndDate">Check-out Date</label></h5>
                    </div>
                    <div class="col-8">
                        <input type="date" class="form-control" asp-for="Reservation.EndDate" id="endDate" />
                        <span class="text-danger" asp-validation-for="Reservation.EndDate"></span>
                    </div>
                </div>

                <!-- Site Type Selection -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label>Site Types</label></h5>
                    </div>
                    <div class="col-8">
                        <div id="siteTypeCheckboxes">
                            @foreach (var siteType in Model.SiteTypes)
                            {
                                if (siteType.SiteTypeId != 5) // Exclude Short Term Storage
                                {
                                    <div class="form-check">
                                        <input class="form-check-input site-type-checkbox" type="checkbox" value="@siteType.SiteTypeId" id="siteType_@siteType.SiteTypeId" checked="@(Model.Reservation.Site != null && Model.Reservation.Site.SiteTypeId == siteType.SiteTypeId)" />
                                        <label class="form-check-label" for="siteType_@siteType.SiteTypeId">
                                            @siteType.Name: <span class="text-success font-weight-bold" id="siteTypePrice_@siteType.SiteTypeId"></span>
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Handicapped Filter -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label>Show Handicapped Sites</label></h5>
                    </div>
                    <div class="col-8">
                        <input type="checkbox" id="showHandicapped" />
                        <label for="showHandicapped">Include Handicapped-Accessible Sites</label>
                    </div>
                </div>

                <!-- Trailer Length -->
                <div class="form-group row mb-3" id="trailerLengthSection">
                    <div class="col-4">
                        <h5><label asp-for="Reservation.TrailerLength">Trailer Length (ft)</label></h5>
                    </div>
                    <div class="col-8">
                        <input class="form-control" asp-for="Reservation.TrailerLength" id="trailerLength" />
                        <span id="trailerLengthNote" class="text-muted small"></span>
                        <span class="text-danger" asp-validation-for="Reservation.TrailerLength"></span>
                    </div>
                </div>

                <!-- Number of Vehicles -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <label>Number of Vehicles</label>
                    </div>
                    <div class="col-8">
                        <select id="NumberOfVehicles" name="NumberOfVehicles" class="form-control">
                            @{
                                for (int i = 0; i <= 3; i++)
                                {
                                    var selected = (Model.Reservation.NumberOfVehicles == i) ? "selected" : "";
                                    <option value="@i" selected="@selected">@i</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- License Plates -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <label>Vehicle License Plates</label>
                    </div>
                    <div class="col-8" id="plateInputs"></div>
                </div>


                <!-- Site Selection -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label>Campsite</label></h5>
                    </div>
                    <div class="col-8">
                        <div class="input-group">
                            @Html.DropDownListFor(m => m.Reservation.SiteId, Model.SiteList, "- Select a site -", new { @class = "form-control", @id = "siteDropdown" })
                            <button type="button" class="btn btn-outline-primary" id="pickOnMap" data-bs-toggle="modal" data-bs-target="#siteMapModal">
                                Pick on Map
                            </button>
                        </div>
                        <span class="text-danger" asp-validation-for="Reservation.SiteId"></span>
                    </div>
                </div>

                <!-- Handicapped Site Message -->
                <div class="form-group row mb-3" id="handicappedMessage" style="display: none;">
                    <div class="col-8 offset-4">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Reserved for our Wounded Warriors: You have selected a handicapped-accessible site. Please ensure you require this accommodation, as these sites are reserved for those with accessibility needs.
                        </div>
                    </div>
                </div>

                <!-- PCS orders Message -->
                <div class="form-group row mb-3" id="PCSMessage" style="display: none;">
                    <div class="col-sm-8 offset-sm-4">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Your reservation is over 180 days. To be able to stay this long, you will need to provide proof of PCS orders so that we can accomodate you.
                        </div>
                    </div>
                </div>

                <!-- Transaction Summary -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label>Original Total</label></h5>
                    </div>
                    <div class="col-8">
                        <input class="form-control" readonly value="$@Model.OriginalTotal.ToString("F2")" />
                    </div>
                </div>

                <div class="form-group row mb-3" id="feeChangesSection">
                    <div class="col-4">
                        <h5><label>Changes in Transactions</label></h5>
                    </div>
                    <div class="col-8">
                        <div id="feeChangesContent">
                            <span class="text-muted">No changes yet</span>
                        </div>
                    </div>
                </div>

                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label>New Total</label></h5>
                    </div>
                    <div class="col-8">
                        <input class="form-control bg-light font-weight-bold" id="newTotal" readonly value="$@Model.OriginalTotal.ToString("F2")" />
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="form-group row mb-3">
                    <div class="col-8 offset-4">
                        <div class="row">
                            <div class="col-6">
                                <button type="submit" class="btn btn-primary form-control" id="saveChanges" disabled>
                                    Save Changes
                                </button>
                            </div>
                            <div class="col-6">
                                <a asp-page="./Index" class="btn btn-secondary form-control">Back to List</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Additional Options -->
            <div class="col-4 p-4 border-left">
                <h4 class="text-primary mb-3">Additional Options</h4>

                <div class="mb-3">
                    <!-- Check Availability Button -->
                    <button type="button" id="checkAvailability" class="btn btn-outline-info btn-block" disabled>
                        <i class="fas fa-calendar-check"></i> Check Availability
                    </button>
                </div>

                <button type="button"
                        class="btn btn-outline-danger"
                        onclick="cancelReservation(@Model.Reservation.ReservationId)">
                    <i class="fas fa-ban"></i> Cancel Reservation
                </button>

                <div class="mt-3">
                    @if (Model.Reservation.ReservationStatus == SD.PendingReservation)
                    {
                        <p>This reservation requires documents to be approved before it can be confirmed.</p>
                    }

                    @if (Model.Reservation.RequiresDisability.HasValue && Model.Reservation.RequiresDisability.Value == true)
                    {
                        <div class="mb-3">
                            @if (!Model.DisabilityDocument.IsApproved)
                            {
                                @if (Model.Reservation.ReservationStatus == SD.PendingReservation)
                                {
                                    <button id="btnConfirmDisability"
                                            type="button"
                                            class="btn btn-outline-success w-100"
                                            onclick="confirmDisability(@Model.Reservation.ReservationId)">
                                        <i class="fas fa-check"></i> Confirm Disability Access
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="alert alert-success d-flex align-items-center justify-content-between">
                                    <span><i class="fas fa-check-circle me-2"></i> Disability Documents Approved</span>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-warning"
                                            onclick="revertDisability(@Model.Reservation.ReservationId)">
                                        <i class="fas fa-undo"></i> Revert
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    @if (Model.Reservation.RequiresPCS.HasValue && Model.Reservation.RequiresPCS.Value == true)
                    {
                        <div class="mb-3">
                            @if (!Model.PCSOrders.IsApproved)
                            {
                                @if (Model.Reservation.ReservationStatus == SD.PendingReservation)
                                {
                                    <button id="btnConfirmPCS"
                                            type="button"
                                            class="btn btn-outline-success w-100"
                                            onclick="confirmPCSOrders(@Model.Reservation.ReservationId)">
                                        <i class="fas fa-check"></i> Confirm PCS Orders
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="alert alert-success d-flex align-items-center justify-content-between">
                                    <span><i class="fas fa-check-circle me-2"></i> PCS Orders Approved</span>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-warning"
                                            onclick="revertPCSOrders(@Model.Reservation.ReservationId)">
                                        <i class="fas fa-undo"></i> Revert
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>

                
                <!-- Availability Status Box -->
                <div class="mt-4 p-3 border rounded bg-light" id="availabilityStatus">
                    <h5>Availability Status</h5>
                    <p class="text-muted">Make changes to dates, site types, or site and click "Check Availability" to verify.</p>
                </div>

                <!-- Site Information -->
                <div class="mt-4" id="siteInfo" style="display: none;">
                    <h5>Selected Site Information</h5>
                    <div id="siteInfoContent">
                        <!-- Will be filled by JavaScript -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SVG Map Modal -->
    <div class="modal fade" id="siteMapModal" tabindex="-1" aria-labelledby="siteMapModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title" id="siteMapModalLabel"><i class="fas fa-map-marked-alt"></i> Select a Campsite</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="map-container">
                        <!-- Colorblind Mode Toggle - Top Right -->
                        <div class="colorblind-toggle-top">
                            <label for="colorblind-mode-toggle">Colorblind Mode</label>
                            <div class="toggle-switch">
                                <input type="checkbox" id="colorblind-mode-toggle" />
                                <span class="toggle-slider"></span>
                            </div>
                            <p style="font-size: .75em">(use scroll wheel to zoom)</p>
                        </div>
                        <input type="hidden" id="chosenSiteId" asp-for="Reservation.SiteId"/>


                        <!-- Map Controls -->
                        <div class="map-controls d-flex justify-content-between align-items-center mb-2">
                            <h4 class="mb-0">RV Park Layout</h4>

                            <!-- Legend only -->
                            <div class="legend">
                                <div class="legend-item">
                                    <div class="legend-color legend-available" style="background-color: var(--accent-color);"></div>
                                    <span>Available</span>
                                </div>
                                <div class="legend-item">
                                    <div class="legend-color legend-unavailable" style="background-color: var(--secondary-color)"></div>
                                    <span>Unavailable</span>
                                </div>
                                <div class="legend-item">
                                    <div class="legend-color legend-selected" style="background-color: var(--gold-accent);"></div>
                                    <span>Selected</span>
                                </div>
                            </div>

                            <button id="zoom-out-btn" class="btn btn-primary btn-sm" disabled title="Reset map to full view">
                                <i class="fas fa-search-minus"></i> Zoom Out
                            </button>
                        </div>

                        <!-- SVG Map -->
                        <div id="svg-map" class="svg-map">
                            Loading map...
                        </div>
                        <div class="site-tooltip" id="site-tooltip"></div>
                    </div>
                    <!-- Mini Map -->
                    <div id="mini-map-container">
                        <svg id="mini-map" width="100%" height="100%"></svg>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Confirm Selection</button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/js/siteMap.js"></script>
    <script>
        $(document).ready(function () {
            const rvSiteTypeIds = [1, 2, 3, 6, 7]; // Premium Pull-Through, Premium Back-In, Standard, Wagon Wheel, Partial Hookup
            let changesMade = false;
            let isProgrammaticChange = false;
            let isInitializing = true; // Flag to prevent redundant initialization calls
            let isMapUpdating = false; // Prevent multiple map updates
            let fetchTimeout = null; // For debouncing fetchAvailableSites
            let isTrailerLengthUpdating = false; // Prevent infinite loops in trailer length logic

            // For updating the prices listed by the SiteType checkboxes
            const siteTypes = @Html.Raw(Json.Serialize(Model.SiteTypes));
            const siteTypePrices = @Html.Raw(Json.Serialize(Model.SiteTypePrices));

            const originalSiteId = $('#originalSiteId').val();
            const originalStartDate = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OriginalStartDate));
            const originalEndDate = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OriginalEndDate));
            const dateStartDate = new Date(originalStartDate);
            const dateEndDate = new Date(originalEndDate);
            const numDays = Math.floor((dateEndDate - dateStartDate) / (1000 * 60 * 60 * 24));
            const initialReservationStatus = '@Model.Reservation.ReservationStatus';
            const tentSiteTypeId = 4; // Tent/Overflow
            const standardSiteTypeId = 3; // Standard (45ft limit)


            //For adding the current site to the lists and such
            const currentSiteId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Reservation.SiteId));
            const currentSiteTypeId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Reservation.Site.SiteTypeId));
            const currentSitePrice = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CurrentSitePrice ?? 50.0m));
            const currentTrailerMaxSize = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Reservation.Site.TrailerMaxSize));
            const currentSiteType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Reservation.Site.SiteType.Name));
            const currentSiteName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Reservation.Site.Name));
            const currentHandicapAccessible = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Reservation.Site.IsHandicappedAccessible));

            //const requiresPCS = checkPCS();
            

            //dropdown.prop('disabled', true);
            $('#siteDropdown').prop('disabled', true);

            //to minimize disruption making custom parsedecimal that will not break the map.
            function parsedecimal(value) {
                try {
                    // Attempt to parse the value using parseFloat
                    const result = parseFloat(value);
                    if (isNaN(result)) {
                        console.warn(`parsedecimal: Failed to parse "${value}" as a number, returning NaN`);
                        return NaN;
                    }
                    return result;
                } catch (error) {
                    console.error(`parsedecimal: Error parsing "${value}":`, error);
                    return NaN;
                }
            }

            // Initialize default selections
            function initializeDefaultSelections() {
                // Uncheck all checkboxes first
                $('.site-type-checkbox').prop('checked', false);

                // get the site type from the current reservation
                const currentSiteId = '@Model.Reservation.SiteId';
                if (currentSiteId && currentSiteId !== '0' && currentSiteId !== '') {
                    $.ajax({
                        url: '/api/Reservation/GetSiteDetails',
                        type: 'GET',
                        data: { siteId: currentSiteId },
                        success: function(response) {
                            if (response && response.siteTypeId) {
                                $('#siteType_' + response.siteTypeId).prop('checked', true);
                                initializeTrailerLengthVisibility();
                                updateValidationMessages();
                            }
                        }
                    });
                }
            }

            // Initialize trailer length visibility
            function initializeTrailerLengthVisibility() {
                const hasRvChecked = $('.site-type-checkbox:checked').toArray()
                    .some(cb => rvSiteTypeIds.includes(parseInt($(cb).val())));
                const showHandicapped = $('#showHandicapped').is(':checked');

                // Show trailer length section if RV types are selected or handicapped filter is checked
                const shouldShowTrailerLength = hasRvChecked || showHandicapped;
                $('#trailerLengthSection').toggle(shouldShowTrailerLength);

                // Only clear trailer length if no RV types and handicapped filter is off
                if (!hasRvChecked && !showHandicapped) {
                    $('#trailerLength').val('');
                    console.log('Cleared trailer length because no RV types selected and handicapped filter off');
                }

                if (!isInitializing) {
                    updateValidationMessages();
                    validateForm();
                }
            }

            function updateValidationMessages() {
                $('.validation-message').remove();

                const hasRvChecked = $('.site-type-checkbox:checked').toArray()
                    .some(cb => rvSiteTypeIds.includes(parseInt($(cb).val())));
                const hasTentChecked = $('#siteType_' + tentSiteTypeId).is(':checked');
                const trailerLength = parsedecimal($('#trailerLength').val()) || 0;
                const hasStandardChecked = $('#siteType_' + standardSiteTypeId).is(':checked');

                // Show standard site restriction message
                if (trailerLength > 45 && !hasStandardChecked) {
                    $('#siteType_' + standardSiteTypeId).closest('.form-check').append(
                        '<div class="validation-message text-warning ms-4"><small>Standard sites limited to 45 ft trailers</small></div>'
                    );
                }

                // Show tent restriction message
                if (trailerLength > 0 && !hasTentChecked) {
                    $('#siteType_' + tentSiteTypeId).closest('.form-check').append(
                        '<div class="validation-message text-warning ms-4"><small>Tent sites not suitable for trailers</small></div>'
                    );
                }
            }

            function enforceCheckboxRules(clickedCheckbox = null) {
                if (isProgrammaticChange || isTrailerLengthUpdating) return;

                const clickedValue = clickedCheckbox ? parseInt($(clickedCheckbox).val()) : null;
                const clickedIsChecked = clickedCheckbox ? $(clickedCheckbox).is(':checked') : false;

                const tentChecked = $('#siteType_' + tentSiteTypeId).is(':checked');
                const rvChecked = $('.site-type-checkbox:checked').toArray()
                    .some(cb => rvSiteTypeIds.includes(parseInt($(cb).val())));

                isProgrammaticChange = true;

                // If tent was just clicked and checked, uncheck all RV types, clear trailer length, and uncheck handicapped
                if (clickedValue === tentSiteTypeId && clickedIsChecked) {
                    rvSiteTypeIds.forEach(typeId => {
                        $('#siteType_' + typeId).prop('checked', false);
                    });
                    $('#trailerLength').val('');
                    $('#showHandicapped').prop('checked', false);
                    console.log('Tent checked: unchecked all RV types, cleared trailer length, and unchecked handicapped');
                }
                // If an RV type was just clicked and checked, uncheck tent
                else if (rvSiteTypeIds.includes(clickedValue) && clickedIsChecked) {
                    $('#siteType_' + tentSiteTypeId).prop('checked', false);
                    console.log('RV type checked: unchecked tent');
                }

                isProgrammaticChange = false;

                // Update visibility and validation
                initializeTrailerLengthVisibility();
                updateValidationMessages();
            }

            // Debounce function to limit rapid AJAX calls
            function debounce(func, wait) {
                return function executedFunction(...args) {
                    clearTimeout(fetchTimeout);
                    fetchTimeout = setTimeout(() => func.apply(this, args), wait);
                };
            }

            // Function to populate site information
            function populateSiteInfo(siteId) {
                console.log('populateSiteInfo called with siteId:', siteId);
                if (!siteId || siteId === '0' || siteId === '') {
                    console.log('No valid siteId provided, hiding siteInfo');
                    $('#siteInfo').hide();
                    $('#siteInfoContent').empty();
                    $('#handicappedMessage').hide();
                    $('#trailerLengthNote').text('').hide();
                    return;
                }

                $('#siteInfo').show();
                $('#siteInfoContent').html('<p>Loading site details...</p>');

                $.ajax({
                    url: '/api/Reservation/GetSiteDetails',
                    type: 'GET',
                    data: { siteId: siteId, referenceDate: $('#startDate').val() || '' },
                    timeout: 5000,
                    success: function (response) {
                        console.log('GetSiteDetails response:', response);
                        if (response && response.name) {
                            window.siteData[response.name] = {
                                siteId: response.siteId.toString(),
                                name: response.name,
                                trailerMaxSize: response.trailerMaxSize,
                                siteType: response.siteTypeName,
                                siteTypeId: response.siteTypeId,
                                pricePerDay: response.pricePerDay,
                                isHandicappedAccessible: response.isHandicappedAccessible || false
                            };
                            // Sync with siteMap.js siteData
                            siteData = window.siteData;
                            $('#siteInfoContent').html(`
                                <p><strong>Name:</strong> ${response.name}</p>
                                <p><strong>Description:</strong> ${response.description || 'N/A'}</p>
                                <p><strong>Max Trailer Size:</strong> ${response.trailerMaxSize ? response.trailerMaxSize + ' ft' : 'N/A'}</p>
                                <p><strong>Price Per Day:</strong> $${response.pricePerDay ? response.pricePerDay.toFixed(2) : 'N/A'}</p>
                                ${response.sitePhoto ? `<img src="${response.sitePhoto}" style="max-width: 250px; width: 100%; height: auto; border: 1px solid #ddd; border-radius: 5px;" alt="${response.name} Image" />` : '<p>No image available</p>'}
                            `);
                            const isRvSite = response.siteTypeId && rvSiteTypeIds.includes(response.siteTypeId);
                            $('#trailerLengthSection').toggle(isRvSite);
                            if (!isRvSite) {
                                $('#trailerLength').val('');
                            }
                           // $('#trailerLengthNote').text(response.trailerMaxSize ? `Maximum allowed: ${response.trailerMaxSize} ft` : '').toggle(response.trailerMaxSize);
                            $('#siteDropdown').data('siteTypeId', response.siteTypeId || '');
                            $('#siteDropdown').data('maxTrailerSize', response.trailerMaxSize || '');
                            updateHandicappedMessage(siteId);
                        } else {
                            console.warn('Invalid or empty site data received:', response);
                            $('#siteInfoContent').html('<p class="text-danger">Invalid site data received.</p>');
                            $('#handicappedMessage').hide();
                            $('#trailerLengthNote').text('').hide();
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('GetSiteDetails error:', status, error, xhr.responseText);
                        $('#siteInfoContent').html(`<p class="text-danger">Error loading site details: ${error}</p>`);
                        $('#handicappedMessage').hide();
                        $('#trailerLengthNote').text('').hide();
                    }
                });
            }

            // Initialize site selection and info
            const initialSiteId = '@Model.Reservation.SiteId';
            if (initialSiteId && initialSiteId !== '0' && initialSiteId !== '') {
                console.log('Initializing with siteId:', initialSiteId);
                $('#siteDropdown').val(initialSiteId);
                populateSiteInfo(initialSiteId);
            } else {
                console.log('No initial siteId, hiding siteInfo');
                $('#siteInfo').hide();
            }

            // Pre-fetch available sites to initialize window.siteData
            async function initializeAvailableSites() {
                const selectedSiteTypes = $('.site-type-checkbox:checked').map(function () {
                    return parseInt($(this).val());
                }).get();
                if (selectedSiteTypes.length > 0) {
                    await fetchAvailableSites(); // Wait for fetch to complete
                    // Sync with siteMap.js siteData
                    siteData = window.siteData;
                    console.log('Synced siteData with window.siteData:', siteData);
