                })
                .then(r => r.json())
                .then(() => location.reload());
            }
        }
    </script>

    <script>
        $(document).ready(function () {

            function renderPlates(count) {
                let container = $('#plateInputs');
                container.empty();

                for (let i = 1; i <= count; i++) {
                    container.append(`
                        <div class="mb-2">
                            <input class="form-control"
                                   type="text"
                                   name="VehiclePlate${i}"
                                   placeholder="Vehicle #${i} Plate"
                                   maxlength="10"
                                   required />
                        </div>
                    `);
                }

                // Fill existing values if editing
                const platesRaw = @Html.Raw(Json.Serialize(Model.Reservation.VehiclePlates ?? ""));
                if (platesRaw) {
                    const plates = platesRaw.split(',').map(p => p.trim());
                    plates.forEach((plate, index) => {
                        $(`input[name="VehiclePlate${index+1}"]`).val(plate);
                    });
                }
            }

            // Initialize on page load
            renderPlates(@Model.Reservation.NumberOfVehicles);

            // Re-render on number change
            $('#NumberOfVehicles').change(function () {
                let count = parseInt($(this).val());
                renderPlates(count);
            });

        });

        function cancelReservation(reservationId) {
            if (confirm('Are you sure you want to cancel this reservation? This action cannot be undone.')) {
                $.ajax({
                    url: '/api/Reservation/CancelReservation',
                    type: 'POST',
                    data: JSON.stringify({ reservationId: reservationId}),
                    contentType: 'application/json',
                    success: function (response) {
                        alert(
                            `${response.message}\n` +
                            `Paid: $${response.amountPaid.toFixed(2)}\n` +
                            `Cancellation Fee: $${response.cancellationFee.toFixed(2)}\n` +
                            `Refund: $${response.refundAmount.toFixed(2)}\n` +
                            `Balance Due: $${response.balanceDue.toFixed(2)}`
                        );

                         // If the API returned a receipt URL use it, otherwise navigate to Admin Reservations index
                        const adminIndex = '@Url.Page("/Admin/Reservations/Index")';
                        const redirectUrl = response.receiptUrl || adminIndex;

                        // if (response.receiptUrl) {
                        //     window.location.href = response.receiptUrl;
                        // }

                        if (typeof currDataTable !== 'undefined') currDataTable.ajax.reload();
                        if (typeof pastDataTable !== 'undefined') pastDataTable.ajax.reload();
                        if (typeof dataTable !== 'undefined') dataTable.ajax.reload();

                        window.location.href = redirectUrl;
                    },
                    error: function (xhr) {
                        alert('Error canceling reservation: ' + (xhr.responseText || 'Unknown error.'));
                    }
                });
            }
        }

    </script>



