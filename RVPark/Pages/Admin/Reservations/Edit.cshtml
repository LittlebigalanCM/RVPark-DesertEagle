                const origEnd = originalEndDate ? new Date(originalEndDate + 'T00:00:00').getTime() : null;
                const selEnd = selectedEndDate ? new Date(selectedEndDate + 'T00:00:00').getTime() : null;


                changesMade = (originalSiteId !== selectedSiteId ||
                               origStart !== selStart ||
                               origEnd !== selEnd);

                $('#checkAvailability').prop('disabled', !changesMade);
                $('#saveChanges').prop('disabled', !changesMade);


