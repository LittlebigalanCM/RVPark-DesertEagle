            // Fetch available sites
            async function fetchAvailableSites() {
                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();
                const trailerLength = $('#trailerLength').val() || '';
                const selectedSiteTypes = $('.site-type-checkbox:checked').map(function () {
                    return parseInt($(this).val());
                }).get();
                const showHandicapped = $('#showHandicapped').is(':checked') ?? false;

                console.log('fetchAvailableSites called with:', { startDate, endDate, selectedSiteTypes, trailerLength, showHandicapped });

                // Don't proceed if no site types are selected
                if (!startDate || !endDate || selectedSiteTypes.length === 0) {
                    console.log('Invalid parameters or no site types selected, clearing site dropdown');
                    updateSiteDropdown([], '#siteDropdown');
                    window.siteData = {};
                    siteData = window.siteData; // Sync with siteMap.js

                    // Clear the map if it's open
                    const modal = bootstrap.Modal.getInstance(document.getElementById('siteMapModal'));
                    if (modal && modal._isShown && !isMapUpdating) {
                        isMapUpdating = true;
                        console.log('Clearing map - no site types selected');
                        updateMap([], 0);
                        isMapUpdating = false;
                    }
                    return;
                }

                try {
                
                    let apiUrl = `/api/Reservation/GetAvailableSites?startDate=${startDate}&endDate=${endDate}&siteTypeIds=${selectedSiteTypes.join(',')}&trailerLength=${trailerLength}`;

                    // Add excludeReservationId 
                    // if ('@Model.Reservation.ReservationId' && '@Model.Reservation.ReservationId' !== '0') {
                    //     apiUrl += `&excludeReservationId=${@Model.Reservation.ReservationId}`;
                    // }

                    const response = await $.ajax({
                        url: apiUrl,
                        method: 'GET',
                        dataType: 'json'
                    });

                    console.log('GetAvailableSites response:', response);

                    let filteredSites = response.sites.filter(site => site.siteTypeId !== 5); // Exclude Short Term Storage

                    // Apply site type filter
                    filteredSites = filteredSites.filter(site => selectedSiteTypes.includes(site.siteTypeId));

                    // Apply handicapped filter
                    if (!showHandicapped) {
                        filteredSites = filteredSites.filter(site => !site.isHandicappedAccessible);
                    }


                    console.log('Filtered sites after applying filters:', filteredSites);
                    //I want to add the current reservation's site to the list...
                    // Ensure current reservation site is present so map + dropdown include it
                    if (currentSiteId != null && !filteredSites.some(s => s.siteId.toString() === currentSiteId.toString())) {
                        filteredSites.push({
                            siteId: currentSiteId,
                            name: currentSiteName,
                            trailerMaxSize: currentTrailerMaxSize,
                            siteType: currentSiteType,
                            siteTypeId: currentSiteTypeId,
                            pricePerDay: currentSitePrice,
                            isHandicappedAccessible: currentHandicapAccessible
                        });
                    }

                    window.siteData = {};
                    filteredSites.forEach(site => {
                        const key = site.name
                        window.siteData[key] = {
                            siteId: site.siteId.toString(),
                            name: site.name,
                            trailerMaxSize: site.trailerMaxSize,
                            siteType: site.siteType,
                            siteTypeId: site.siteTypeId,
                            pricePerDay: site.pricePerDay,
                            isHandicappedAccessible: site.isHandicappedAccessible || false
                        };
                    });


                    // Update dropdown and ensure current site is selected by default (if nothing else selected)
                    updateSiteDropdown(filteredSites, '#siteDropdown');
                    if (!$('#siteDropdown').val() && currentSiteId) {
                        // set selection and populate info
                        isProgrammaticChange = true;
                        $('#siteDropdown').val(currentSiteId);
                        populateSiteInfo(currentSiteId);
                        updateHandicappedMessage(currentSiteId);
                        setTimeout(() => { isProgrammaticChange = false; }, 0);
                    }

                    console.log('Updated window.siteData:', window.siteData);

                    // Sync with siteMap.js siteData
                    siteData = window.siteData;

                    updateSiteDropdown(filteredSites, '#siteDropdown');
                    const modal = bootstrap.Modal.getInstance(document.getElementById('siteMapModal'));
                    if (modal && modal._isShown && !isMapUpdating) {
                        isMapUpdating = true;
                        console.log('Updating map with filtered sites:', filteredSites);
                        updateMap(filteredSites, parsedecimal(trailerLength) || 0);
                        isMapUpdating = false;
                    }
                } catch (error) {
                    console.error('Error fetching available sites:', error);
                    updateSiteDropdown([], '#siteDropdown');
                    window.siteData = {};
                    siteData = window.siteData; // Sync with siteMap.js
                }
            }

