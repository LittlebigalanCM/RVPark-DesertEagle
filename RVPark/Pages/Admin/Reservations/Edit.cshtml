            //         alert("An error occurred confirming PCS Orders.");
            //     });
            // });

            // Handle SVG map site selection
            window.onSiteSelected = function (siteId) {
                console.log('onSiteSelected called with siteId:', siteId);
                if (!siteId) {
                    console.log('No siteId provided, ignoring onSiteSelected');
                    return;
                }
                const site = Object.values(window.siteData).find(s => s.siteId.toString() === siteId.toString());
                if (!site) {
                    console.warn(`Site ${siteId} not found in window.siteData`);
                    Swal.fire({
                        icon: 'error',
                            title: 'Invalid Site',
                            text: `The selected site (ID: ${siteId}) is not available. Please choose another site.`,
                    });
                    if (window.deselectSite) {
                        window.deselectSite();
                    }
                    $('#siteDropdown').val('');
                    $('#siteInfo').hide();
                    $('#siteInfoContent').empty();
                    $('#handicappedMessage').hide();
                    $('#trailerLengthNote').text('').hide();
                    return;
                }
                if (siteId && $('#siteDropdown').val() !== siteId && !isProgrammaticChange) {
                    isProgrammaticChange = true;
                    $('#siteDropdown').val(siteId).trigger('change');
                }
            };

            // Modal event handlers
            $('#siteMapModal').on('shown.bs.modal', async function () {
                if (!window.siteMapInitialized) {
                    console.log('Initializing SVG map');
                    await loadSvgMap();
                    window.siteMapInitialized = true;
                }
                if (Object.keys(window.siteData).length === 0) {
                    console.log('window.siteData is empty, fetching available sites');
                    isMapUpdating = true;
                    await fetchAvailableSites();
                    siteData = window.siteData; 
                    isMapUpdating = false;
                }
                if (!isMapUpdating) {
                    isMapUpdating = true;
                    console.log('Updating map with existing siteData:', Object.keys(window.siteData));
                    updateMap(Object.values(window.siteData), parsedecimal($('#trailerLength').val()) || 0);
                    isMapUpdating = false;
                    const siteId = $('#siteDropdown').val();
                    if (siteId && window.selectSiteOnMapById) {
                        console.log('Selecting initial site on map:', siteId);
                        window.selectSiteOnMapById(siteId);
                    }
                }
            });

            $('#siteMapModal').on('hidden.bs.modal', function () {
                console.log('Modal hidden, resetting siteMapInitialized');
                window.siteMapInitialized = false;
                const selectedSiteId = $('#siteDropdown').val();
                if (selectedSiteId) {
                    console.log(`Retaining selected siteId: ${selectedSiteId}`);
                    updateHandicappedMessage(selectedSiteId);
                } else {
                    console.log('No site selected, hiding handicapped message');
                    $('#handicappedMessage').hide();
                }
            });

            // Initialize site type prices and data
            window.siteData = window.siteData || {};

            // Form validation
            function validateForm() {
                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();
                const selectedSiteTypes = $('.site-type-checkbox:checked').length;
                const trailerLength = $('#trailerLength').val();
                const hasRvChecked = $('.site-type-checkbox:checked').toArray()
                    .some(cb => rvSiteTypeIds.includes(parseInt($(cb).val())));
                const hasTentChecked = $('#siteType_4').is(':checked');
                const showHandicapped = $('#showHandicapped').is(':checked');
                const siteId = $('#siteDropdown').val();

                // Form is valid if:
                // 1. Has start and end dates
                // 2. Either has site types selected or handicapped filter is checked
                const hasValidSiteSelection = selectedSiteTypes > 0 || showHandicapped;
                const isValid = startDate && endDate && hasValidSiteSelection;

                $('#pickOnMap').prop('disabled', !isValid);
                $('#checkAvailability').prop('disabled', !isValid || !changesMade);
                $('#saveChanges').prop('disabled', !isValid || !siteId || !changesMade || $('#availabilityStatus h5.text-success').length === 0);

                console.log('Validation:', {
                    startDate: !!startDate,
                    endDate: !!endDate,
                    selectedSiteTypes,
                    showHandicapped,
                    hasValidSiteSelection,
                    hasRvChecked,
                    trailerLength: !!trailerLength,
                    hasTentChecked,
                    isValid
                    });
                  updateValidationMessages();
            }

            // Initialize page
            async function initializePage() {
                initializeTrailerLengthVisibility();
                await initializeAvailableSites();
                isInitializing = false; // Reset initialization flag
                validateForm();
                updateSiteTypePrices();
            }

            initializePage();
        });


        function confirmDisability(reservationId) {
            if(confirm('Has the client sent their Disability documentation?'))
            {
                    fetch("/api/Reservation/ConfirmDisability", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ reservationId: reservationId })
                })
                .then(response => {
                    if (!response.ok) throw new Error("Request failed");
                    return response.json();
                })
                .then(data => {
                    alert(data.message || "Disability Documents confirmed successfully!");
                    location.reload(); // optionally reload page to update status
                })
                .catch(error => {
                    console.error("Error confirming Disability Documents:", error);
                    alert("An error occurred confirming Disability Documents.");
                });
            }
        }

        function confirmPCSOrders(reservationId) {
