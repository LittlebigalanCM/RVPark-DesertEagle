@page
@model RVPark.Pages.Admin.Reservations.IndexModel
@{
    ViewData["Title"] = "Manage Reservations";
}


<div class="d-flex justify-content-between align-items-center">
    <h1 class="text-secondary">Reservations</h1>
    <div>
        <a href="../Error" class="d-none">
            <i class="fas fa-list-check me-2"></i> See PCS/Handicap Approvals
        </a>
        <a href="./Reservations/Create" class="btn btn-success">
            <i class="fas fa-plus me-2"></i> Create New Reservation
        </a>
    </div>
</div>
<div class="card mb-4">
    <div class="card-header">
        <h5 class="my-2"><i class="fas fa-campground me-2"></i> Reservations</h5>
    </div>
    <div class="card-body">
        <form>
            <div class="row align-items-center gy-2">
                <div class="col-lg-3 col-md-6">
                    <input type="text" id="searchInput" class="form-control" placeholder="Reservation ID or Customer Name">
                </div>
                <div class="col-lg-3 col-md-6">
                    @Html.DropDownListFor(m => m.ReservationStatus, Model.ReservationStatusList, " - Filter by Status - ", new { @class = "form-control selectpicker", @id = "statusDropdown", data_live_search = "true" })
                </div>

                <div class="col-lg-3 col-md-6 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-primary" id="searchButton"> <i class="fas fa-search"></i> Search & Filter </button>
                    <button type="button" class="btn btn-danger" id="resetSearch"> Reset </button>
                </div>
            </div>
        </form>

        <table id="reservationsTable" class="table table-striped table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th hidden>Site Number</th> 
                    <th>Site</th>
                    <th>Reservation ID</th>
                    <th>Customer</th>
                    <th>Check-in Date</th>
                    <th>Check-out Date</th>
                    <th hidden>SortOrder</th> 
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Table will be populated by DataTables -->
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/reservations.js"></script>

}