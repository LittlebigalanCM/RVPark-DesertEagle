            // Fetch available sites
            async function fetchAvailableSites() {
                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();
                const trailerLength = $('#trailerLength').val() || '';
                const selectedSiteTypes = $('.site-type-checkbox:checked').map(function() {
                    return parseInt($(this).val());
                }).get();
                const showHandicapped = $('#showHandicapped').is(':checked') ?? true;

                if (!startDate || !endDate || selectedSiteTypes.length === 0) {
                    updatechosenSiteId([], '#chosenSiteId');
                    return;
                }

                try {
                    const response = await $.ajax({
                        url: `/api/Reservation/GetAvailableSites?startDate=${encodeURIComponent(startDate)}&endDate=${encodeURIComponent(endDate)}&siteTypeIds=${selectedSiteTypes.join(',')}&trailerLength=${encodeURIComponent(trailerLength)}`,
                        method: 'GET',
                        dataType: 'json'
                    });

                    let filteredSites = (response.sites || []).filter(site => site.siteTypeId !== 5); // Exclude Short Term Storage
                    if (!showHandicapped) {
                        filteredSites = filteredSites.filter(site => !site.isHandicappedAccessible);
                    }

                    window.siteData = window.siteData || {};
                    // store keyed by siteId (string) for consistent lookup
                    filteredSites.forEach(site => {
                        const key = site.siteId.toString();
                        window.siteData[key] = {
                            siteId: key,
                            name: site.name,
                            trailerMaxSize: site.trailerMaxSize,
                            siteType: site.siteType,
                            siteTypeId: site.siteTypeId,
                            pricePerDay: site.pricePerDay,
                            isHandicappedAccessible: !!site.isHandicappedAccessible
                        };
                    });

                    updatechosenSiteId(filteredSites, '#chosenSiteId');
                    const modal = bootstrap.Modal.getInstance(document.getElementById('siteMapModal'));
                    if (modal && modal._isShown) {
                        updateMap(filteredSites, parseFloat(trailerLength) || 0);
                    }
                } catch (error) {
                    console.error('Error fetching available sites:', error);
                    updatechosenSiteId([], '#chosenSiteId');
                }
            }

            // Update site dropdown
            function updatechosenSiteId(sites, dropdownSelector) {
                const dropdown = $(dropdownSelector);
                dropdown.empty().append('<option value="">- Select a site -</option>');
                if (!sites || sites.length === 0) {
                    dropdown.prop('disabled', true);
                    $('#createButton').prop('disabled', true);
                    return;
                }

                sites.forEach(site => {
                    // site may be server object or normalized object; use site.siteId consistently
                    const id = site.siteId !== undefined ? site.siteId : site.siteId;
                    const isHand = !!site.isHandicappedAccessible;
                    dropdown.append(`<option value="${id}">${site.name} (${site.siteType}${isHand ? ', Handicapped Accessible' : ''})</option>`);
                });
                dropdown.prop('disabled', false);
                validateForm();

                // show handicapped message for the currently selected site
                const selectedId = dropdown.val();
                if (selectedId) {
                    updateHandicappedMessage(selectedId);
                }
            }

