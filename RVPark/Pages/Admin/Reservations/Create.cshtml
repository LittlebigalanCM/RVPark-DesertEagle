@page
@using Infrastructure.Utilities
@model RVPark.Pages.Admin.Reservations.CreateModel
@{
    ViewData["Title"] = "Create Reservation";
}

<form method="post">
    <div class="container">
        <div class="row px-2 mx-2 backgroundWhite border">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="col-12 px-3" style="border-bottom:1px solid #325d88">
                <h2 class="text-primary">Create New Reservation</h2>
                <a type="button" class="link-primary pb-1" data-bs-toggle="modal" data-bs-target="#builderHelpModal">Need help?</a>
            </div>

            @if (Model.IsEmailTaken == true)
            {
                <div id="takenEmailAlert" asp-for="IsEmailTaken" class="alert alert-danger" style="text-align: center;">
                    Email is already taken.
                </div>
            }

            <div class="col-lg-12 pt-3 order-lg-1">
                <!-- Customer Selection -->
                <div class="form-group row mb-3">
                    <div class="col-4">
                        <h5><label>Customer</label></h5>
                    </div>
                    <div class="col-8">
                        <select asp-for="Reservation.UserId" asp-items="Model.UserList" class="form-control selectpicker" id="userDropdown" data-live-search="true">
                            <option value=""> - Select a customer - </option>
                        </select>
                        <span class="text-danger" asp-validation-for="Reservation.UserId"></span>
                    </div>
                </div>

                <!-- Walk-in customer section -->
                <div id="newCustomerForm" class="form-group border border-3 pt-3 mb-3 rounded" style="display: none">
                    <input id="isWalkin" type="hidden" asp-for="IsWalkinReservation" />
                    <div class="form-group row mb-3">
                        <div class="col-4">
                            <h6><label asp-for="FirstName">First Name</label></h6>
                        </div>
                        <div class="col-8">
                            <input id="FirstName" type="text" asp-for="FirstName" autocomplete="off" placeholder="First Name" class="form-control" />
                            <p id="FirstNameValidation" style="color: red; display: none">First name is required</p>
                        </div>
                    </div>
                    <div class="form-group row mb-3">
                        <div class="col-4">
                            <h6><label asp-for="LastName">Last Name</label></h6>
                        </div>
                        <div class="col-8">
                            <input id="LastName" type="text" asp-for="LastName" autocomplete="off" placeholder="Last Name" class="form-control" />
                            <p id="LastNameValidation" style="color: red; display: none">Last name is required</p>
                        </div>
                    </div>
                    <div class="form-group row mb-3">
                        <div class="col-4">
                            <h6><label asp-for="Email"></label></h6>
                        </div>
                        <div class="col-8">
                            <input id="Email" type="email" asp-for="Email" autocomplete="off" placeholder="Email" class="form-control" />
                            <p id="EmailValidation" style="color: red; display: none">Email is required</p>
                        </div>
                    </div>
                    <div class="form-group row mb-3">
                        <div class="col-4">
                            <h6><label asp-for="PhoneNumber">Phone Number</label></h6>
                        </div>
                        <div class="col-8">
                            <input id="PhoneNumber" type="text" asp-for="PhoneNumber" autocomplete="off" placeholder="Phone Number" class="form-control" />
                            <p id="PhoneNumberValidation" style="color: red; display: none">Phone Number is required</p>
                        </div>
                    </div>
                    <div class="form-group row mb-3">
                        <div class="col-4">
                            <h6><label>Military Status</label></h6>
                        </div>
                        <div class="col-8">
                            @Html.DropDownListFor(m => m.SelectedStatusId, Model.MilitaryStatusesList, " - Please select a Military Status - ", new { @class = "form-control selectpicker", @id = "ddlStatuses", data_live_search = "true" })
                            <p id="StatusValidation" style="color: red; display: none">Military status is required</p>
                        </div>
                    </div>
                    <div class="form-group row mb-3">
                        <div class="col-4">
                            <h6><label>Military Branch</label></h6>
                        </div>
                        <div class="col-8">
                            @Html.DropDownListFor(m => m.SelectedBranchId, Model.MilitaryBranchesList, " - Please select a Military Branch - ", new { @class = "form-control selectpicker", @id = "ddlBranches", data_live_search = "true" })
                            <p id="BranchValidation" style="color: red; display: none">Military branch is required</p>
                        </div>
                    </div>
                    <div class="form-group row mb-3">
                        <div class="col-4">
                            <h6><label>Military Rank</label></h6>
                        </div>
                        <div class="col-8">
                            @Html.DropDownListFor(m => m.SelectedRankId, Model.MilitaryRanksList, " - Please select a Military Rank - ", new { @class = "form-control selectpicker", @id = "ddlRanks", data_live_search = "true" })
                            <p id="RankValidation" style="color: red; display: none">Military rank is required</p>
                        </div>
                    </div>
                    
                    <div class="form-group row mb-3">
                        <div class="col-4">
                            <h6><label asp-for="SendingTempPassword">Send Temporary Password?</label></h6>
                        </div>
                        <div class="col-8 pt-3">
                            <input id="tempPassYes" type="radio" asp-for="SendingTempPassword" value="@true" /> Yes </>
                            <input id="tempPassNo" type="radio" asp-for="SendingTempPassword" value="@false" /> No </>

                            <p id="SendTempPasswordValidation" style="color: red; display: none">You must choose whether or not to create a password now or send a temporary one</p>
                        </div>

                    </div>
                    <div id="generatePassword" style="display: none">
                        <div class="form-group row mb-3">
                            <div class="col-4">
                            </div>
                            <div class="col-3">
                                <button id="showTempPassBtn" class="btn btn-primary btn-sm" type="button">Show Temporary Password</button>
                            </div>
                            <div class="col-4">
                                <button id="genNewPassBtn" class="btn btn-primary btn-sm" type="button">Generate New Temporary Password</button>
                            </div>
                        </div>
                        <input id="tmpPass" type="hidden" asp-for="TempPassword" value=@null />
                    </div>
                    <div id="setPassword" style="display: none">
                        <div class="form-group row mb-3">
                            <div class="col-4">
                                <h6><label asp-for="Password"></label></h6>
                            </div>
                            <div class="col-8">
                                <input id="Password" type="password" asp-for="Password" autocomplete="off" placeholder="Password" class="form-control" />
                                <p id="PasswordValidation" style="color: red; display: none">Password is required</p>
                            </div>
                        </div>

                        <div class="form-group row mb-3">
                            <div class="col-4">
                                <h6><label asp-for="ConfirmPassword"></label></h6>
                            </div>
                            <div class="col-8">
                                <input id="ConfirmPassword" type="password" asp-for="ConfirmPassword" autocomplete="off" placeholder="Confirm Password" class="form-control" />
                                <p id="ConfirmPasswordValidation" style="color: red; display: none">Password confirmation is required</p>
                                <p id="MatchingPasswordValidation" style="color: red; display: none">Passwords must match</p>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Dates Section -->
                <div class="form-group row mb-3">
                    <div class="col-sm-4">
                        <h5><label asp-for="Reservation.StartDate">Check-in Date</label></h5>
                    </div>
                    <div class="col-sm-8">
                        <input type="date" class="form-control" asp-for="Reservation.StartDate" id="startDate" />
                        <span class="text-danger" asp-validation-for="Reservation.StartDate"></span>
                    </div>
                </div>

                <div class="form-group row mb-3">
                    <div class="col-sm-4">
                        <h5><label asp-for="Reservation.EndDate">Check-out Date</label></h5>
                    </div>
                    <div class="col-sm-8">
                        <input type="date" class="form-control" asp-for="Reservation.EndDate" id="endDate" />
                        <span class="text-danger" asp-validation-for="Reservation.EndDate"></span>
                    </div>
                </div>

                <!-- Site Type Selection -->
                <div class="form-group row mb-3">
                    <div class="col-sm-4">
                        <h5><label>Site Types</label></h5>
                    </div>
                    <div class="col-sm-8">
                        <div id="siteTypeCheckboxes">
                            <div class="mb-2 d-flex gap-2">
                                <button type="button" id="selectAllSiteTypes"
                                        class="btn btn-outline-primary btn-sm px-2 py-1">
                                    Select All
                                </button>

                                <button type="button" id="deselectAllSiteTypes"
                                        class="btn btn-outline-secondary btn-sm px-2 py-1">
                                    Deselect All
                                </button>
                            </div>
                            @foreach (var siteType in Model.SiteTypes)
                            {
                                if (siteType.SiteTypeId != 5) // Exclude Short Term Storage
                                {
                                    <div class="form-check">
                                        <input class="form-check-input site-type-checkbox" type="checkbox" value="@siteType.SiteTypeId" id="siteType_@siteType.SiteTypeId" checked>
                                        <label class="form-check-label" for="siteType_@siteType.SiteTypeId">
                                            @siteType.Name: <span class="text-success font-weight-bold" id="siteTypePrice_@siteType.SiteTypeId"></span>
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
                <!-- Handicapped Filter -->
                <div class="form-group row mb-3">
                    <div class="col-sm-4">
                        <h5><label>Show Handicapped Sites</label></h5>
                    </div>
                    <div class="col-sm-8">
                        <input type="checkbox" id="showHandicapped" />
                        <label for="showHandicapped">Include Handicapped-Accessible Sites</label>
                    </div>
                </div>


                <!-- Trailer Length - Only visible if RV site types are selected -->
                <div class="form-group row mb-3" id="trailerLengthSection">
                    <div class="col-sm-4">
                        <h5><label asp-for="Reservation.TrailerLength">Trailer Length (ft)</label></h5>
                    </div>
                    <div class="col-sm-8">
                        <input class="form-control" asp-for="Reservation.TrailerLength" id="trailerLength" />
                        <span class="text-danger" asp-validation-for="Reservation.TrailerLength"></span>
                    </div>
                </div>

                <!-- Update Find Available Sites Button to trigger modal -->
                <div class="form-group row mb-3">
                    <div class="col-sm-8 offset-4">
                        <button type="button" class="btn btn-primary" id="findAvailableSites" data-bs-toggle="modal" data-bs-target="#siteMapModal">
                            Find Available Sites
                        </button>
                    </div>
                </div>

                <!-- Site Selection - Initially disabled -->
                <div class="form-group row mb-3">
                    <div class="col-sm-4">
                        <h5><label>Campsite</label></h5>
                    </div>
                    <div class="col-sm-8">
                        <select asp-for="Reservation.SiteId" class="form-control" id="chosenSiteId" disabled>
                            <option value="">- Select a site -</option>
                        </select>
                        <span class="text-danger" asp-validation-for="Reservation.SiteId"></span>
                    </div>
                </div>
                <!-- Handicapped Site Message -->
                <div class="form-group row mb-3" id="handicappedMessage" style="display: none;">
                    <div class="col-8 offset-4">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Reserved for our Wounded Warriors: You have selected a handicapped-accessible site. Please ensure you require this accommodation, as these sites are reserved for those with accessibility needs.
                        </div>
                    </div>
                </div>

                <!-- PCS orders Message -->
                <div class="form-group row mb-3" id="PCSMessage" style="display: none;">
                    <div class="col-sm-8 offset-sm-4">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Your reservation is over 180 days. To be able to stay this long, you will need to provide proof of PCS orders so that we can accomodate you.
                        </div>
                    </div>
                </div>

                <!-- Number of Vehicles -->
                <div class="form-group row mb-3" id="vehicleSection">
                    <div class="col-sm-4">
                        <h5>
                            <label for="NumberOfVehicles">Number of Vehicles</label>
                        </h5>
                        <p class="text-info small">Only vehicles with license plates need to be counted.</p>
                    </div>

                    <div class="col-sm-8">

                        <!-- No C#, Razor will auto-select based on asp-for -->
                        <select asp-for="NumberOfVehicles" class="form-select" id="NumberOfVehicles" name="NumberOfVehicles">
                            <option value="1">1 Vehicle</option>
                            <option value="2">2 Vehicles</option>
                            <option value="3">3 Vehicles</option>
                        </select>

                        <div id="vehiclePlateFields">

                            <div class="mb-3" id="vehiclePlate1Wrapper">
                                <label class="form-label fw-bold">Vehicle #1 License Plate</label>
                                <input asp-for="VehiclePlate1"
                                       class="form-control"
                                       maxlength="10" />
                            </div>

                            <div class="mb-3" id="vehiclePlate2Wrapper">
                                <label class="form-label fw-bold">Vehicle #2 License Plate</label>
                                <input asp-for="VehiclePlate2"
                                       class="form-control"
                                       maxlength="10" />
                            </div>

                            <div class="mb-3" id="vehiclePlate3Wrapper">
                                <label class="form-label fw-bold">Vehicle #3 License Plate</label>
                                <input asp-for="VehiclePlate3"
                                       class="form-control"
                                       maxlength="10" />
                            </div>

                        </div>

                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="form-group row mb-3">
                    <div class="col-sm-8 offset-sm-4">
                        <div class="row">
                            <input id="resStatus" type="hidden" asp-for="Reservation.ReservationStatus" />
                            <div class="col-12 col-lg-6 mb-2 mb-lg-0">
                                <button type="submit" class="btn btn-success form-control" id="createButton">
                                    Continue to Summary
                                </button>
                            </div>
                            <div class="col-12 col-sm-6">
                                <a asp-page="./Index" class="btn btn-secondary form-control">Back to List</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- SVG Map Modal -->
    <div class="modal fade" id="siteMapModal" tabindex="-1" aria-labelledby="siteMapModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title" id="siteMapModalLabel"><i class="fas fa-map-marked-alt"></i> Select a Campsite</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="background-color: lightgrey">
                    <div class="map-container">
                        <!-- Colorblind Mode Toggle - Top Right -->
                        <div class="colorblind-toggle-top">
                            <label for="colorblind-mode-toggle">Colorblind Mode</label>
                            <div class="toggle-switch">
                                <input type="checkbox" id="colorblind-mode-toggle" />
                                <span class="toggle-slider"></span>
                            </div>
                            <p style="font-size: .75em">(use scroll wheel to zoom)</p>
                        </div>

                        <!-- Map Controls -->
                        <div class="map-controls d-flex justify-content-between align-items-center mb-2">
                            <h4 class="mb-0">RV Park Layout</h4>

                            <!-- Legend only -->
                            <div class="legend">
                                <div class="legend-item">
                                    <div class="legend-color legend-available" style="background-color: var(--accent-color);"></div>
                                    <span>Available</span>
                                </div>
                                <div class="legend-item">
                                    <div class="legend-color legend-unavailable" style="background-color: var(--secondary-color)"></div>
                                    <span>Unavailable</span>
                                </div>
                                <div class="legend-item">
                                    <div class="legend-color legend-selected" style="background-color: var(--gold-accent);"></div>
                                    <span>Selected</span>
                                </div>
                            </div>

                            <button id="zoom-out-btn" class="btn btn-primary btn-sm" disabled title="Reset map to full view">
                                <i class="fas fa-search-minus"></i> Reset Zoom
                            </button>
                        </div>

                        <!-- SVG Map -->
                        <div id="svg-map" class="svg-map">
                            Loading map...
                        </div>
                        <div class="site-tooltip" id="site-tooltip"></div>
                    </div>
                    <!-- Mini Map -->
                    <div id="mini-map-container">
                        <svg id="mini-map" width="100%" height="100%"></svg>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal" onclick="document.getElementById('continueButton').click()">Confirm Selection</button>
                    <button type="button" id="continueButton" hidden></button>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Need Help? Modal -->
<div class="modal fade" id="builderHelpModal" tabindex="-1" aria-labelledby="builderHelpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="builderHelpModalLabel">How to Create a Reservation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ol class="mb-3">
                    <li class="mb-2">
                        Select the Guest to make a reservation for. Additionally, a new account can be created if they are a walk-in that has not made an account.
                    </li>
                    <li class="mb-2">
                        Select <strong>check-in</strong> and <strong>check-out</strong> dates.
                    </li>
                    <li class="mb-2">
                        Select site types to search for, select handicapped accessiblity (if applicable).
                    </li>
                    <li class="mb-2">
                        Enter the trailer length (if applicable).
                    </li>
                    <li class="mb-2">
                        Select 'Find Available Sites' to view the site map.
                    </li>
                    <li>
                        Select a site and continue to complete the reservation.
                    </li>
                </ol>

                <p class="mb-1"><strong>Note:</strong></p>
                <ul>
                    <li>Wagon Wheel Pull-through sites are available by phone reservation only.</li>
                    <li>A <b>Standard Site</b> can accomodate up to two license plates.</li>
                    <li>A <b>Premium Site</b> can accomodate up to three license plates.</li>
                </ul>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" data-bs-dismiss="modal">Got it</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Only load Bootstrap Select CSS and JS if not already loaded -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/css/bootstrap-select.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/js/bootstrap-select.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/siteMap.js"></script>

    <!-- Military Branch/Rank Script -->
    <script>
        $(document).ready(function() {
            console.log("Page loaded, initializing dropdowns...");

            // Initialize the ranks dropdown as disabled because no branch is selected initially
            $("#ddlRanks").prop('disabled', true);

            // Function to properly clear and populate the ranks dropdown
            function updateRanksDropdown(ranks, disabled = false, message = "- Please select a Military Rank -") {
                var rankDropdown = $("#ddlRanks");

                // Check if Bootstrap Select is initialized
                var isSelectPicker = rankDropdown.hasClass('selectpicker') && rankDropdown.data('selectpicker');

                if (isSelectPicker) {
                    // For Bootstrap Select
                    rankDropdown.selectpicker('destroy');
                }

                // Clear and populate
                rankDropdown.empty();
                rankDropdown.append('<option value="">' + message + '</option>');

                if (ranks && ranks.length > 0) {
                    $.each(ranks, function(i, rank) {
                        rankDropdown.append('<option value="' + rank.id + '">' + rank.rank + '</option>');
                    });
                }

                rankDropdown.prop('disabled', disabled);

                // Reinitialize Bootstrap Select if it was originally one
                if (rankDropdown.hasClass('selectpicker')) {
                    rankDropdown.selectpicker({
                        liveSearch: true,
                        width: '100%'
                    });
                }
            }

            // Handle branch selection change
            $("#ddlBranches").change(function() {
                var branchId = $(this).val();
                console.log("Branch selected:", branchId);

                if (!branchId || branchId === "") {
                    console.log("No branch selected, clearing ranks");
                    updateRanksDropdown(null, true, "- Please select a Military Branch first -");
                    return;
                }

                console.log("Loading ranks for branch:", branchId);
                updateRanksDropdown(null, true, "Loading ranks...");

                // Make AJAX call
                $.ajax({
                    url: "/api/Military/GetRanksByBranch",
                    type: "GET",
                    data: { branchId: branchId },
                    dataType: "json",
                    success: function(data) {
                        console.log("Ranks received:", data);
                        console.log("Number of ranks:", data ? data.length : 0);

                        if (data && data.length > 0) {
                            updateRanksDropdown(data, false);
                            console.log("Ranks dropdown updated with", data.length, "ranks");
                        } else {
                            updateRanksDropdown(null, true, "No ranks found for this branch");
                            console.log("No ranks found for this branch");
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error("AJAX Error:", status, error);
                        console.error("Response:", xhr.responseText);
                        updateRanksDropdown(null, true, "Error loading ranks");
                        Swal.fire({
                            icon: 'error',
                            title: 'Error Loading Ranks',
                            text: 'Failed to load military ranks. Please try again.',
                        });
                    }
                });
            });

            // Initialize SelectPicker for all military dropdowns
            $("#ddlBranches, #ddlStatuses").selectpicker({
                liveSearch: true,
                width: '100%'
            });

            // Initialize ranks dropdown with SelectPicker
            $("#ddlRanks").selectpicker({
                liveSearch: true,
                width: '100%'
            });

            // Handle pre-selected branch
                var selectedBranchId = $("#ddlBranches").val();
                if (selectedBranchId && selectedBranchId !== "") {
                console.log("Found pre-selected branch:", selectedBranchId);
                $("#ddlBranches").trigger('change');
            }
        });
    </script>

    <script>
        $(document).ready(function() {
            const rvSiteTypeIds = [1, 2, 3, 6, 7];
            let tmpPass = null;
            let radio = document.getElementById("tempPassYes");
            radio.checked = false;

            radio = document.getElementById("tempPassNo");
            radio.checked = false;

            function checkWalkIn()
            {

                console.log("click");
                console.log($("#tempPassYes").val())
                if ($("#userDropdown").val() == "New Customer") {



                    $("#newCustomerForm").show();

                    $("#isWalkin").val(true);

                    console.log($("#tempPassNo").is(':checked'))



                } else {
                    $("#newCustomerForm").hide();
                    $("#isWalkin").val(false);

                    console.log($("#tempPassNo").is(':checked'))


                }
            }

            $("#userDropdown").change(checkWalkIn);
            //const userDropdown = document.getElementById('userDropdown')

            //userDropdown.addEventListener('change', checkWalkIn);

            function Str_Random(length) {
                let result = '';
                const lower = 'abcdefghijklmnopqrstuvwxyz';
                const upper = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
                const numbers = '0123456789';
                const special = '!$*';

                const allCharacters = [lower, upper, numbers, special];
                // Loop to generate characters for the specified length
                for (let i = 0; i < length; i++) {

                    const charSetIndex = i % allCharacters.length;
                    console.log(allCharacters)
                    const randomInd = Math.floor(Math.random() * allCharacters[charSetIndex].length);
                    result += allCharacters[charSetIndex].charAt(randomInd);
                }
                return result;
            }

            function ShowTempPassword()
            {
                Swal.fire({
                    icon: 'info',
                    title: 'New Temporary Password',
                    text: tmpPass
                    })
            }

            $("#showTempPassBtn").click(ShowTempPassword)

            function GenerateNewPassword()
            {
                tmpPass = Str_Random(8);
                Swal.fire({
                    icon: 'info',
                    title: 'New Temporary Password',
                    text: tmpPass
                    })

                $("#tmpPass").val(tmpPass)

            }

            $("#genNewPassBtn").click(GenerateNewPassword)

            function tempPassword()
            {
                var sendTempPassword = $("#tempPassYes").is(':checked')

                if (sendTempPassword == false)
                {
                    $("#setPassword").show();
                    $("#generatePassword").hide();
                    $("#tmpPass").val(null);

                }
                else
                {

                    $("#setPassword").hide();
                    $("#generatePassword").show();

                    if (tmpPass == null)
                    {
                        tmpPass = Str_Random(8);
                    }
                    Swal.fire({
                            icon: 'info',
                            title: 'Temp Password',
                            text: tmpPass
