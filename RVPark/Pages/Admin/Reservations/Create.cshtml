            // Generate random password
            function Str_Random(length) {
                let result = '';
                const lower = 'abcdefghijklmnopqrstuvwxyz';
                const upper = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
                const numbers = '0123456789';
                const special = '!$*';
                const allCharacters = [lower, upper, numbers, special];

                for (let i = 0; i < length; i++) {
                    const charSetIndex = i % allCharacters.length;
                    const randomInd = Math.floor(Math.random() * allCharacters[charSetIndex].length);
                    result += allCharacters[charSetIndex].charAt(randomInd);
                }
                return result;
            }

