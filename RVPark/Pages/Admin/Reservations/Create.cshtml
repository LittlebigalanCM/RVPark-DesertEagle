                    return;
                }
                window.siteData = window.siteData || {};
                const key = siteId.toString();
                // prefer direct lookup by siteId key, fallback to scanning values (keeps compatibility)
                const site = window.siteData[key] || Object.values(window.siteData).find(s => s && s.siteId && s.siteId.toString() === key);
                console.log('updateHandicappedMessage lookup:', { key, site });
                const isAccessible = !!(site && (site.isHandicappedAccessible || site.isHandicapAccessible));
                if (isAccessible) {
                    console.log(`Showing handicapped message for site: ${site.name}`);
                    handicappedMessage.show();
                } else {
                    console.log(`Hiding handicapped message for siteId: ${siteId}`);
                    handicappedMessage.hide();
                }
            }

            // Update listed SiteType Prices based on user's selected dates
            function updateSiteTypePrices() {
                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();

                // If dates are missing, just use today's date for startDate and a week later for endDate
                let userStart = new Date();
                let userEnd = new Date(userStart.getDate() + 7);

                if (startDate && endDate) {
                    userStart = new Date(startDate);
                    userEnd = new Date(endDate);
                }

                for (const st of siteTypes) {
                    const el = document.getElementById(`siteTypePrice_${st.siteTypeId}`);
                    if (!el) continue;

                    // Get all prices. If there are none (which there shouldn't ever be), inform the user
                    const prices = siteTypePrices[st.siteTypeId];
                    if (!prices || prices.length === 0) {
                        el.innerHTML = "<em>No pricing available</em>";
                        continue;
                    }

                    // Find any prices whose date ranges overlap with the selected range
                    const applicable = prices.filter(p => {
                        const pStart = new Date(p.startDate);
                        const pEnd = p.endDate ? new Date(p.endDate) : null;

                        // Overlap test:
                        // priceStart <= userEnd AND (priceEnd is null OR priceEnd >= userStart)
                        return (
                            pStart <= userEnd &&
                            (!pEnd || pEnd >= userStart)
                        );
                    }).sort((a, b) => new Date(a.startDate) - new Date(b.startDate)); // Sort by startDate

                    if (applicable.length === 0) {
                        el.innerHTML = "<em>No prices for selected dates</em>";
                        continue;
                    }

                    // Formatting

                    const multiplePrices = applicable.length > 1; // To format prices correctly if there are multiple
                    const finalPrice = applicable[applicable.length - 1]; // To make sure no comma is added if it's the last price shown

                    // Iterate through every applicable Price and append formatted text to htmlParts (the "return" here is what's appending, it's not returning the func at large)
                    const htmlParts = applicable.map(p => {
                        const pStartTxt = new Date(p.startDate).toLocaleDateString();
                        const pEndTxt = p.endDate
                            ? "to " + new Date(p.endDate).toLocaleDateString()
                            : "- ongoing";

                        // Format differently depending on whether it has a set endDate or whether multiple prices are used
                        if (p.endDate === null && multiplePrices === false)
                        { // There's only one price, and it's indefinite
                            return `$${p.pricePerDay.toFixed(2)}/night`;
                        }
                        else
                        { // There are either more than one price, or there's an endDate that the user might want to know about, or both
                            return `$${p.pricePerDay.toFixed(2)}/night <small>(${pStartTxt} ${pEndTxt})</small>` + (p != finalPrice ? ", " : "");
                        }
                    });

                    el.innerHTML = htmlParts.join("");
                }
            }

            $('#startDate, #endDate').on('change', updateSiteTypePrices);

            // Date change handlers
            $('#startDate').change(function() {
                const startDate = $(this).val();
                if (startDate) {
