                    // If trailer length entered, uncheck tent and handicapped
                    if ($('#siteType_' + tentSiteTypeId).is(':checked')) {
                        $('#siteType_' + tentSiteTypeId).prop('checked', false);
                        $('#showHandicapped').prop('checked', false);
                        console.log('Trailer length entered: unchecked tent and handicapped');
                    }
                    // If trailer > 45ft, uncheck standard
                    if (trailerLength > 45 && $('#siteType_' + standardSiteTypeId).is(':checked')) {
                        $('#siteType_' + standardSiteTypeId).prop('checked', false);
                        console.log('Trailer length > 45ft: unchecked standard');
                    }
                    isProgrammaticChange = false;
                    initializeTrailerLengthVisibility();
                } else {
                    updateValidationMessages();
                }

                // Debounce
                clearTimeout(window.trailerLengthTimeout);
                window.trailerLengthTimeout = setTimeout(() => {
                    fetchAvailableSites();
                    validateForm();
                }, 500);
            });

            $('#trailerLength').on('change', function() {
                enforceCheckboxRules();
                fetchAvailableSites();
                validateForm();
            });

            $('#NumberOfVehicles').on('change', function() {
                enforceCheckboxRules();
                fetchAvailableSites();
                validateForm();
            });

            // Handicapped filter change handler
            $('#showHandicapped').change(function() {
                if ($(this).is(':checked') && $('#siteType_' + tentSiteTypeId).is(':checked')) {
                    isProgrammaticChange = true;
                    $('#siteType_' + tentSiteTypeId).prop('checked', false);
                    console.log('Handicapped checked: unchecked tent');
                    isProgrammaticChange = false;
                }
                initializeTrailerLengthVisibility();
                fetchAvailableSites();
                validateForm();
            });

            // Site dropdown change handler
            $('#chosenSiteId').change(function() {
                if (isProgrammaticChange) {
                    console.log('Programmatic change detected, resetting isProgrammaticChange');
                    isProgrammaticChange = false;
                    return;
                }
                const siteId = $(this).val();
                console.log('chosenSiteId changed to siteId:', siteId);
                if (siteId) {
                    if (!window.siteMapSelectionInProgress) {
                        setTimeout(() => {
                            if (window.selectSiteOnMapById) {
                                console.log('Calling selectSiteOnMapById with:', siteId);
                                window.siteMapSelectionInProgress = true;
                                window.selectSiteOnMapById(siteId);
                                window.siteMapSelectionInProgress = false;
                            } else {
                                console.warn('selectSiteOnMapById not defined');
                            }
                        }, 200);
                    }
                } else {
                    console.log('No site selected, hiding siteInfo');
                    $('#handicappedMessage').hide();
                }
                validateForm();
            });

            // Find Available Sites button click
                   $('#findAvailableSites').click(function() {
            const userId = $('#userDropdown').val();
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();
            const selectedSiteTypes = $('.site-type-checkbox:checked').map(function() {
                return parseInt($(this).val());
            }).get();
            const hasRvChecked = selectedSiteTypes.some(id => rvSiteTypeIds.includes(id));
            const trailerLength = hasRvChecked ? ($('#trailerLength').val() || "") : "";

            if (!userId || !startDate || !endDate) {
                Swal.fire({
                    icon: 'error',
                    title: 'Missing Fields',
                    text: 'Please fill in all required fields.',
                });
                return;
            }

            if (selectedSiteTypes.length === 0) {
                Swal.fire({
                    icon: 'error',
                    title: 'No Site Type Selected',
                    text: 'Please select at least one site type.',
                });
                return;
            }



            window.isCheckAvailabilityTriggered = true;
            fetchAvailableSites();
        });

            // Form submission validation
            $('#createButton').click(async function(e) {
                e.preventDefault();
                $('.trailer-length-validation').remove();

                if ($("#userDropdown").val() === "New Customer") {
                    $("#isWalkin").val(true);
                    const valid = ValidateNewUser();
                    if (!valid) {
                        return false;
                    }
                } else {
                    $("#isWalkin").val(false);
                }

                const selectedSiteTypes = $('.site-type-checkbox:checked').map(function() {
                    return parseInt($(this).val());
                }).get();
                const trailerLength = $('#trailerLength').val();
                const hasRvChecked = selectedSiteTypes.some(id => rvSiteTypeIds.includes(id));
                const hasTentOnlyChecked = selectedSiteTypes.length === 1 && selectedSiteTypes.includes(tentSiteTypeId);
                const showHandicapped = $('#showHandicapped').is(':checked');
                const siteId = $('#chosenSiteId').val();
                let selectedSite = siteId ? (window.siteData && (window.siteData[siteId] || Object.values(window.siteData).find(s => s.siteId && s.siteId.toString() === siteId.toString()))) : null;

                if (!siteId) {
                    Swal.fire({
                        icon: 'error',
                        title: 'No Site Selected',
                        text: 'Please select a campsite.',
                    });
                    return false;
                }

                // Check if trailer length is required
                const needsTrailerLength = (hasRvChecked || (selectedSiteTypes.length === 0 && showHandicapped)) && !hasTentOnlyChecked;
                if (needsTrailerLength && !trailerLength) {
                    $('#trailerLengthSection .form-group').append(
                        '<div class="trailer-length-validation text-danger mt-1"><small>Please enter trailer length for RV sites</small></div>'
                    );
                    Swal.fire({
                        icon: 'error',
                        title: 'Trailer Length Required',
                        text: 'Please enter a valid trailer length.',
                    });
                    return false;
                }

                if (!selectedSite) {
                    try {
                        console.log('Fetching site details for siteId:', siteId);
                        const response = await $.ajax({
                            url: `/api/Reservation/GetSiteDetails?siteId=${encodeURIComponent(siteId)}`,
                            method: 'GET',
                            dataType: 'json'
                        });
                        if (response) {
                            selectedSite = {
                                siteId: response.siteId.toString(),
                                name: response.name,
                                trailerMaxSize: response.trailerMaxSize,
                                siteType: response.siteTypeName,
                                siteTypeId: response.siteTypeId,
                                pricePerDay: response.pricePerDay,
                                isHandicappedAccessible: response.isHandicappedAccessible || false
                            };
                            window.siteData[response.name] = selectedSite;
                            console.log('Fetched site details:', selectedSite);
                        }
                    } catch (error) {
                        console.error('Error fetching site details:', error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Site Data Error',
                            text: 'Unable to fetch site details. Please try again.',
                        });
                        return false;
                    }
                }

                if (!selectedSite) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Site Data Error',
                        text: 'Selected site data not found. Please try again.',
                    });
                    return false;
                }

                const isTentSiteSelected = selectedSite && (selectedSite.siteTypeId === 4 || selectedSite.siteType === 'Tent/Overflow');

                if (hasRvChecked && !trailerLength && !isTentSiteSelected) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Missing Trailer Length',
                        text: 'Please enter a trailer length for RV sites.',
                    });
                    return false;
                }

                // Validate trailer length against site max
                if (trailerLength && selectedSite.trailerMaxSize && parseFloat(trailerLength) > selectedSite.trailerMaxSize) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid Trailer Length',
                        text: `Trailer length (${trailerLength} ft) exceeds site maximum (${selectedSite.trailerMaxSize} ft).`,
                    });
                    return false;
                }

                // Check if the selected site is handicapped-accessible and show SweetAlert
                if (selectedSite.isHandicappedAccessible) {
                    const result = await Swal.fire({
                        icon: 'info',
                        title: 'Handicapped-Accessible Site Selected',
                        text: 'You have selected a handicapped-accessible site. Please confirm you require this accommodation.',
                        showCancelButton: true,
                        confirmButtonText: 'Confirm',
                        cancelButtonText: 'Select Another Site'
                    });

                    if (!result.isConfirmed) {
                        console.log('User cancelled handicapped site confirmation');
                        return false;
                    }
                    console.log('User confirmed handicapped site, submitting form');
                } else {
                    console.log('Non-handicapped site selected, submitting form');
                }
                //If the booking is more than 180 days, requires PCS orders to be sent in.
                //reservation will have to be pending at this point
                const requiresPCS = (() => {
                    const startDate = new Date($('#startDate').val()+ 'T00:00:00');
                    const endDate = new Date($('#endDate').val()+ 'T00:00:00');

                    const diffTime = endDate.getTime() - startDate.getTime();
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                    console.log('PCS check', { startDate, endDate, diffDays });
                    return diffDays > 180;
                })();

                const PCSMessage = $('#PCSMessage');


                //Sweet alert for PCS
                if(requiresPCS){
                    console.log(`Showing PCS message`);
                    PCSMessage.show();

                    const result = await Swal.fire({
                            icon: 'info',
                            title: 'PCS Orders Required',
                            text: 'The reservation is over 180 days. The customer will need to provide proof of PCS orders. Please confirm that they intend to stay this long and that they will provide the appropriate documentation.',
                            showCancelButton: true,
                            confirmButtonText: 'Confirm',
                            cancelButtonText: 'Change Dates'
                        });

                    if (!result.isConfirmed) {
                        console.log('User cancelled PCS confirmation');
                        return;
                    }
                    console.log('User confirmed PCS orders, submitting form');

                } else {
                    console.log('PCS orders not required, submitting form');
                    console.log(`Hiding PCS message`);
                    PCSMessage.hide();
                }
                // Submit the form
                $(this).closest('form').submit();
            });

            // Handle SVG map site selection
            window.onSiteSelected = function(siteId) {
                console.log('onSiteSelected called with siteId:', siteId);
                if (siteId && $('#chosenSiteId').val() !== siteId && !isProgrammaticChange) {
                    isProgrammaticChange = true;
                    $('#chosenSiteId').val(siteId).trigger('change');
                }
            };

            // Modal event handlers
            $('#siteMapModal').on('shown.bs.modal', function() {
                if (!window.siteMapInitialized) {
                    console.log('Initializing SVG map');
                    loadSvgMap();
                    window.siteMapInitialized = true;
                } else if (Object.keys(window.siteData).length > 0) {
                    console.log('Updating map with existing siteData');
                    updateMap(Object.values(window.siteData), parseFloat($('#trailerLength').val()) || 0);
                    const siteId = $('#chosenSiteId').val();
                    if (siteId) {
                        updateHandicappedMessage(siteId);
                    }
                }
            });

            $('#siteMapModal').on('hidden.bs.modal', function() {
                console.log('Modal hidden, resetting siteMapInitialized');
                window.siteMapInitialized = false;
                const selectedSiteId = $('#chosenSiteId').val();
                if (selectedSiteId) {
                    console.log(`Retaining selected siteId: ${selectedSiteId}`);
                    updateHandicappedMessage(selectedSiteId);
                } else {
                    console.log('No site selected, hiding handicapped message');
                    $('#handicappedMessage').hide();
                }
            });

            // Form validation
            function validateForm() {
                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();
                const selectedSiteTypes = $('.site-type-checkbox:checked').length;
                const trailerLength = $('#trailerLength').val();
                const hasRvChecked = $('.site-type-checkbox:checked').toArray()
                    .some(cb => rvSiteTypeIds.includes(parseInt($(cb).val())));
                const hasTentChecked = $('#siteType_4').is(':checked');
                const showHandicapped = $('#showHandicapped').is(':checked');
                const siteId = $('#chosenSiteId').val();
                const userId = $('#userDropdown').val();

                const hasValidSiteSelection = selectedSiteTypes > 0 || showHandicapped;
                const isValid = startDate && endDate && hasValidSiteSelection && userId;

                $('#findAvailableSites').prop('disabled', !isValid);
                $('#createButton').prop('disabled', !isValid || !siteId);

                console.log('Validation:', {
                    startDate: !!startDate,
                    endDate: !!endDate,
                    selectedSiteTypes,
                    showHandicapped,
                    hasValidSiteSelection,
                    hasRvChecked,
                    trailerLength: !!trailerLength,
                    hasTentChecked,
                    userId: !!userId,
                    isValid
                });

                updateValidationMessages();
            }

            // Initialize site type prices and data
            window.siteData = window.siteData || {};

            // Initialize walk-in check
            checkWalkIn();
            $("#userDropdown").change(checkWalkIn);
        });
    </script>

    <!-- Image Modal Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var img = document.getElementById('siteMapImage');
            var modal = document.getElementById('imageModal');
            var modalImg = document.getElementById('modalImg');
            var closeBtn = document.getElementById('closeModal');
            var zoomInBtn = document.getElementById('zoomInBtn');
            var zoomOutBtn = document.getElementById('zoomOutBtn');
            var zoomResetBtn = document.getElementById('zoomResetBtn');
            var currentZoom = 1;
            var zoomStep = 0.2;
            var minZoom = 1;
            var maxZoom = 4;

            var isPanning = false;
            var startX = 0, startY = 0;
            var translateX = 0, translateY = 0;

            function resetPan() {
                translateX = 0;
                translateY = 0;
                modalImg.style.transform = `scale(${currentZoom}) translate(0px, 0px)`;
            }

            if (img) img.onclick = function () {
                modal.style.display = "flex";
                modalImg.src = this.src;
                currentZoom = 1;
                resetPan();
            };
            else console.log("Skipped img loading...")

            if (closeBtn) closeBtn.onclick = function () {
                modal.style.display = "none";
            };

            if (zoomInBtn) zoomInBtn.onclick = function () {
                if (currentZoom < maxZoom) {
                    currentZoom += zoomStep;
                    modalImg.style.transform = `scale(${currentZoom}) translate(${translateX / currentZoom}px, ${translateY / currentZoom}px)`;
                }
            };
            if (zoomOutBtn) zoomOutBtn.onclick = function () {
                if (currentZoom > minZoom) {
                    currentZoom -= zoomStep;
                    modalImg.style.transform = `scale(${currentZoom}) translate(${translateX / currentZoom}px, ${translateY / currentZoom}px)`;
                }
            };
            if (zoomResetBtn) zoomResetBtn.onclick = function () {
                currentZoom = 1;
                resetPan();
            };

            if (modalImg)
            {
                modalImg.addEventListener('wheel', function (e) {
                    e.preventDefault();
                    if (e.deltaY < 0 && currentZoom < maxZoom) {
                        currentZoom += zoomStep;
                    } else if (e.deltaY > 0 && currentZoom > minZoom) {
                        currentZoom -= zoomStep;
                    }
                    modalImg.style.transform = `scale(${currentZoom}) translate(${translateX / currentZoom}px, ${translateY / currentZoom}px)`;
                });

                modalImg.addEventListener('mousedown', function (e) {
                    if (currentZoom === 1) return;
                    isPanning = true;
                    modalImg.style.cursor = 'grabbing';
                    startX = e.clientX - translateX;
                    startY = e.clientY - translateY;
                    e.preventDefault();
                });
            }

            document.addEventListener('mousemove', function (e) {
                if (!isPanning) return;
                translateX = e.clientX - startX;
                translateY = e.clientY - startY;
                modalImg.style.transform = `scale(${currentZoom}) translate(${translateX / currentZoom}px, ${translateY / currentZoom}px)`;
            });

            document.addEventListener('mouseup', function () {
                if (isPanning) {
                    isPanning = false;
                    modalImg.style.cursor = 'grab';
                }
            });

            if (modal) modal.onclick = function (e) {
                if (e.target === modal) {
                    modal.style.display = "none";
                }
            };
        });

        $(document).ready(function () {
            function updateVehiclePlateFields() {
                const count = parseInt($('#NumberOfVehicles').val()) || 0;

                $('#vehiclePlate1Wrapper').toggle(count >= 1);
                $('#vehiclePlate2Wrapper').toggle(count >= 2);
                $('#vehiclePlate3Wrapper').toggle(count >= 3);
            }

            function updateVehicleLimits() {
                const selectedIds = $('.site-type-checkbox:checked')
                    .map(function () { return parseInt($(this).val()); })
                    .get();

                if (selectedIds.includes(4)) {
                    $('#vehicleSection').hide();
                    $('#NumberOfVehicles').val("1");
                    updateVehiclePlateFields();
                    return;
                }

                $('#vehicleSection').show();

                const hasPremium = selectedIds.includes(1) || selectedIds.includes(2);
                const hasNonPremiumRv = selectedIds.includes(3) || selectedIds.includes(7);

                let max = 2;
                if (hasPremium && !hasNonPremiumRv) {
                    max = 3;
                }

                let current = parseInt($('#NumberOfVehicles').val());
                if (current > max || isNaN(current)) {
                    $('#NumberOfVehicles').val(max);
                    current = max;
                }

                // I THINK this is the code that grays out the 3 vehicle option.
                // TODO: Considering this is commented out now, double-check whether any of this function is even necessary.
                // $('#NumberOfVehicles option').each(function () {
                //     const val = parseInt($(this).val());
                //     $(this).prop('disabled', val > max);
                // });

                updateVehiclePlateFields();
            }

            $('#NumberOfVehicles').on('change', updateVehiclePlateFields);

            $('.site-type-checkbox').on('change', updateVehicleLimits);

            //it defaults to no generated password, so...
            $("#setPassword").show();

            updateVehicleLimits();
            updateVehiclePlateFields();
        });

    </script>

