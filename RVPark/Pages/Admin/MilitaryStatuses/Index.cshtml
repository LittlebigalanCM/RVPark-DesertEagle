@page
@model RVPark.Pages.Admin.MilitaryStatuses.IndexModel
@{
}

<div class="d-flex justify-content-between align-items-center">
    <h1 class="text-secondary">Military Statuses</h1>
    <a href="/Admin/MilitaryStatuses/Upsert?statusId=0" class="btn btn-success"> <i class="fas fa-plus"></i> Create Status</a>

</div>
<div class="card mb-4">
    <div class="card-header">
        <h5 class="my-2"><i class="fa-solid fa-jet-fighter"></i> Military Status</h5>
    </div>

    <div class="card-body">
        <form method="post" asp-page-handler="Search">
            <div class="row align-items-center gy-2">
                <div class="col-lg-3 col-md-6">
                    <input type="text" id="searchStatusInput" class="form-control" placeholder="Search for Status">
                </div>
                <div class="col-lg-3 col-md-6 d-flex justify-content-end gap-2">
                    <button class="btn btn-primary" type="button" id="searchStatusButton">
                        <i class="fas fa-search"></i> Search
                    </button>
                    <button id="resetStatusSearch" class="btn btn-danger">
                        Reset
                    </button>
                </div>
            </div>
        </form>
        <table id="Military_Status_table" class="table table-striped table-bordered" style="width:100%">

            <thead>
                <tr>
                    <th>
                        Status
                    </th>
                    <th>
                        Actions
                    </th>
                </tr>
            </thead>

        </table>
    </div>
</div>
@section Scripts
{
    <script src="~/js/military.js"> </script>

    <script>

        $(document).ready(function () {
            loadList();
        });

        function loadList() {

            dataTable = $('#Military_Status_table').DataTable({
                "ajax": {
                    "url": "/api/military/GetMilitaryStatuses",
                    "type": "GET",
                    "datatype": "json",
                   },

                "columns": [
                    { data: "status", width: "10%" },

                    {
                        data: "id", width: "5%",
                        "render": function (data) {
                            return `<div class="text-center">
                                        <a href="/Admin/MilitaryStatuses/Upsert?statusId=${data}" class="btn btn-success btn-sm me-1">
                                        <i class="fas fa-edit"></i> Edit
                                        </a>
                                    </div>`;
                        }
                    }
                ],
                "searching": true,
                "language": {
                    "emptyTable": "no data found."
                },
                "width": "100%",
                "dom": "lrtip"
            });
             //search button
                $('#searchStatusButton').on('click', function () {
                    const value = $('#searchStatusInput').val();
                    dataTable.search(value).draw();
                });
                //adding for enter key press
                $('#searchStatusInput').on('keypress', function (e) {
                    if (e.which === 13) {
                        e.preventDefault();
                        const value = $(this).val();
                        dataTable.search(value).draw();
                    }
                 });

                // Reset button
                $('#resetStatusSearch').on('click', function (e) {
                     e.preventDefault();
                    $('#searchStatusInput').val('');
                    dataTable.search('').draw();
                });
        }
    </script>
}