@page
@model RVPark.Pages.Admin.SiteTypes.CreateModel
@{
    ViewData["Title"] = "Create Site Type";
}

<div class="col-12 px-3" style="border-bottom:1px solid #325d88">
    <h2 class="text-primary">Create New Site Type</h2>
</div>
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mt-2">
                <span class="text-danger">*</span>
                <label asp-for="SiteType.Name" class="control-label"></label>
                <input asp-for="SiteType.Name" class="form-control" />
                <span asp-validation-for="SiteType.Name" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <span class="text-danger">*</span>
                <label for="PricePerDay" class="control-label">Price Per Day</label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text">$</span>
                    </div>
                    <input asp-for="PricePerDay" class="form-control" type="number" step="0.01" min="0.01" />
                </div>
                <span asp-validation-for="PricePerDay" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Create" class="btn btn-primary" />
				<a class="btn btn-secondary" asp-page="Index">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}