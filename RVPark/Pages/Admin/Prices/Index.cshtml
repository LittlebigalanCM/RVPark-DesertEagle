@page
@using ApplicationCore.Models
@model RVPark.Pages.Admin.Prices.IndexModel
@inject Infrastructure.Data.ApplicationDbContext _context
@{
    ViewData["Title"] = "Prices";

    // Get prices from the database directly in the view
    var allPrices = _context.Price
        .Where(p => p.SiteType != null)
        .OrderByDescending(p => p.StartDate)
        .ThenBy(p => p.EndDate)
        .ToList();
}
<div class="d-flex justify-content-between align-items-center">
    <h1 class="text-secondary">Price History</h1>
    <a asp-page="/Admin/SiteTypes/Index" class="btn btn-secondary">
        Back to Site Types
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="my-2"><i class="fas fa-dollar-sign me-2"></i> Price History</h5>
    </div>
    <div class="card-body">
        <table class="table table-striped table-bordered" id="allPricesTable">
            <thead>
                <tr>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Site Type </th>
                    <th>Price Per Day</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var price in allPrices)
                {
                    <tr>
                        <td>@price.StartDate.ToShortDateString()</td>
                        <td>@(price.EndDate.HasValue ? price.EndDate.Value.ToShortDateString() : "Ongoing")</td>
                        <td>@(price.SiteType != null ? price.SiteType.Name : "Unknown")</td>
                        <td>@string.Format("{0:C}", price.PricePerDay)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            $('#allPricesTable').DataTable({
                "orderCellsTop": true,
                "paging": true,
                "order": [[1, "desc"], [0, "asc"]], // Order by start date (newest first), then end date
                "columnDefs":[{
                    targets: "_all",
                    orderable: false
                }],
                "info": true,
                "searching": true,
                "responsive": true,
                "autoWidth": false, 
                "initComplete": function () {
                    this.api()
                        .columns(2)
                        .every(function () {
                            let column = this;

                            let select = document.createElement('select');
                            select.add(new Option(''));
                            //column.footer().replaceChildren(select);
                            column.header().appendChild(select);

                            select.addEventListener('change', function () {
                                column
                                    .search(select.value, {exact: true})
                                    .draw();
                            });

                            column
                                .data()
                                .unique()
                                .sort()
                                .each(function (d, j) {
                                    select.add(new Option(d));
                                });
                        });
                }
            });
        });
    </script>
}
