@page "{handler?}"
@using ApplicationCore.Models
@model RVPark.Pages.Admin.Users.IndexModel
@{
}


<div class="d-flex justify-content-between align-items-center">
   <h1 class="text-secondary">User List</h1>
   <a asp-page="/Account/Register" asp-area="Identity" class="btn btn-success"><i class="fas fa-plus"></i> &nbsp; Create New</a>    
</div>
<div class="card mb-4">
    <div class="card-header">
        <h5 class="my-2"><i class="fa-solid fa-users"></i>Users</h5>
    </div>
    <div class="card-body">
    <form method="post" asp-page-handler="Search">
        <div class="row pb-3">
            <div class="col-sm-4">
                    <input id="userSearchBar" type="text" asp-for="@Model.UserSearchQuery" placeholder="Search Users" value="@Model.UserSearchQuery" class="form-control" />
            </div>

            <div class="col-md-2">
                @Html.DropDownListFor(m => m.SelectedSearchType, Model.SearchTypeList, " - Search by All - ", new { @class = "form-control selectpicker", @id = "ddlSearchType", data_live_search = "true" })
            </div>

            <div class="col-md-2">
                @Html.DropDownListFor(m => m.SelectedRole, Model.RolesList, " - Filter by Role - ", new { @class = "form-control selectpicker", @id = "ddlRole", data_live_search = "true" })
            </div>
            

        </div>
        <div class="row pb-3 justify-content-md-center">
           
            <div class="col-4">
                @Html.DropDownListFor(m => m.SelectedBranch, Model.BranchList, " - Filter by Military Branch - ", new { @class = "form-control selectpicker", @id = "ddlBranch", data_live_search = "true" })
            </div>
            <div class="col-4">
                @Html.DropDownListFor(m => m.SelectedRank, Model.RankList, " - Filter by Military Rank - ", new { @class = "form-control selectpicker", @id = "ddlRank", data_live_search = "true" })
            </div>
            <div class="col-4">
                @Html.DropDownListFor(m => m.SelectedStatus, Model.StatusList, " - Filter by Military Status - ", new { @class = "form-control selectpicker", @id = "ddlStatus", data_live_search = "true" })
            </div>
        </div>
		<div class="col-lg-3 col-md-6 d-flex justify-content gap-2">
			<button type="submit" class="btn btn-primary"> Search & Filter </button>
			<input type="hidden" id="userSearchResetBtn" asp-for="@Model.ResettingSearch" value="" />
			<button onclick="ResetSiteSearch()" type="submit" class="btn btn-danger"> Reset </button>
        </div>
    </form>


    <input type="hidden" id="success" value=@Model.Success.ToString()>
    <input type="hidden" id="message" value=@Model.Message>
    <table id="userTable" class="table table-striped table-bordered">
        <thead>
            <tr>
                <th scope="col">Full Name</th>
                <th scope="col">E-Mail</th>
                <th scope="col">Phone Number</th>
                <th scope="col">Military Branch</th>
                <th scope="col">Military Rank</th>
                <th scope="col">Military Status</th> 
                <th scope="col">Role(s)</th>
                <th scope="col">Lock/Unlock</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.ApplicationUsers != null)
            {
            
                foreach (var user in Model.ApplicationUsers)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        
                        @if (user.MilitaryBranch != null)
                        {
                            <td> @user.MilitaryBranch.BranchName </td>
                        }
                        else
                        {
                            <td> None </td>
                        }

                        @if (user.MilitaryRank != null)
                        {
                            <td> @user.MilitaryRank.Rank </td>
                        }
                        else
                        {
                            <td> None </td>
                        }

                        @if (user.MilitaryStatus != null)
                        {
                            <td> @user.MilitaryStatus.Status </td>
                        }
                        else
                        {
                            <td> None </td>
                        }


                        <td>
                            @{
                                if (Model.UserRoles[user.Id].Count() == 1)
                                {
                                    @Model.UserRoles[user.Id].First()
                                }
                                else
                                {
                                    <ul>
                                        @{
                                            foreach (var r in Model.UserRoles[user.Id])
                                            {
                                                <li>
                                                    @r
                                                </li>
                                            }
                                        }
                                    </ul>
                                }
                            }

                        </td>
                        <td>
                            <form method="post">
                                @{
                                    if (user.LockoutEnd > DateTime.UtcNow)
                                    {
                                        <button type="submit" class="btn btn-danger" asp-page-handler="lockUnlock" asp-route-id="@user.Id"><i class="fas fa-lock-open"></i> Unlock</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-warning" asp-page-handler="lockUnlock" asp-route-id="@user.Id"><i class="fas fa-lock"></i> Lock</button>
                                    }
                                }
                            </form>
                        </td>
                        <td>
                            <a class="btn btn-success" asp-page="/Admin/Users/Update" asp-route-id="@user.Id">Update</a>

                        </td>
                    </tr>
                }
            
            }
        </tbody>
    </table>
    </div>
</div>
@section Scripts {
    <script>
        //make search bar for description equal to the one for name..
        function ResetSiteSearch()
        {
            var reset = document.getElementById("userSearchResetBtn");

            reset.value = true;

            var searchType = document.getElementById("ddlSearchType");
            searchType.selectedIndex = 0;

            var siteType = document.getElementById("ddlRole");
            siteType.selectedIndex = 0;

            var branch  = document.getElementById("ddlBranch");
            branch.selectedIndex = 0;

            var rank  = document.getElementById("ddlRank");
            rank.selectedIndex = 0;

            var status  = document.getElementById("ddlStatus");
            status.selectedIndex = 0;


            var searchBar = document.getElementById("userSearchBar");

            searchBar.value = "";


        }
    </script>
    
    
    <script>
           $(document).ready(function () {
           $('#userTable').DataTable({
               "paging": true,
               "ordering": true,
               "info": true,
               "searching": false,
               "responsive": true,
               "autoWidth": false
           });
        });
    </script>
    <script>
        function alertFunc() {
            var success = $("#success").html()
            var message = $("#message").html();
            console.log(success);
            console.log(message);
            if (success == "True") {
                toastr.success(message);
            };

        }
        window.onload = alertFunc();
    </script>
}


