                    const checkInDate = new Date(startDate);

                    // Set endDate min = startDate + 1 day
                    const minEndDate = new Date(checkInDate);
                    minEndDate.setDate(minEndDate.getDate() + 1);
                    const minEndStr = minEndDate.toISOString().split('T')[0];
                    $('#endDate').attr('min', minEndStr);

                    // Set endDate max = startDate + 180 days
                    const maxEndDate = new Date(checkInDate);
                    maxEndDate.setDate(maxEndDate.getDate() + 180);
                    const maxEndStr = maxEndDate.toISOString().split('T')[0];
                    $('#endDate').attr('max', maxEndStr);

                    const checkOutDate = new Date(checkInDate);
                    checkOutDate.setDate(checkInDate.getDate() + numDays);
                    $('#endDate').val(checkOutDate.toISOString().split('T')[0]);
