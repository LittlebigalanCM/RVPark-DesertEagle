                    //do I need to calculate the fee changes?
            });

            // Check for changes
            function checkForChanges() {
                const currentSiteId = $('#chosenSiteId').val();
                const currentStartDate = $('#startDate').val();
                const currentEndDate = $('#endDate').val();

                changesMade = (originalSiteId !== currentSiteId ||
                               originalStartDate !== currentStartDate ||
                               originalEndDate !== currentEndDate);

                siteNote = ($('#selectSiteNote').text() == '')

                $('#saveChanges').prop('disabled', !changesMade || !siteNote);
                return changesMade;
            }

            // Calculate fee changes
            function calculateFeeChanges() {
                if (!checkForChanges()) {
                    $('#feeChangesContent').html('<span class="text-muted">No changes yet</span>');
                    $('#newTotal').val('$@Model.CurrentTotal.ToString("F2")');
                    return;
                }

                $('#feeChangesContent').html(`
                    <div class="spinner-border text-primary spinner-border-sm" role="status">
                        <span class="sr-only">Calculating...</span>
                    </div> Calculating...
                `);

                const data = {
                    reservationId: @Html.Raw(Json.Serialize(Model.Reservation.ReservationId)),
                    siteId: $('#chosenSiteId').val(),
                    startDate: $('#startDate').val(),
                    endDate: $('#endDate').val()
                };

                $.ajax({
                    url: '/api/Reservation/CalculateFeeChanges',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    timeout: 5000, // 5-second timeout
                    success: function (response) {
                        console.log('CalculateFeeChanges response:', response); // Debugging
                        let feeChangesHtml = '';

                        if (response.feeChangeAmount === 0) {
                            feeChangesHtml = `<span class="text-muted">No fee changes</span>`;
                        } else if (response.feeChangeAmount > 0) {
                            feeChangesHtml = `<span class="text-danger">Additional charge: $${response.feeChangeAmount.toFixed(2)}</span>`;
                        } else {
                            feeChangesHtml = `<span class="text-success">Refund due: $${Math.abs(response.feeChangeAmount).toFixed(2)}</span>`;
                        }

                        $('#feeChangesContent').html(feeChangesHtml);
                        $('#newTotal').val('$' + response.newTotal.toFixed(2));
                    },
                    error: function (xhr, status, error) {
                        console.error('CalculateFeeChanges error:', status, error, xhr.responseText);
                        $('#feeChangesContent').html(`
                            <span class="text-danger">Error calculating fees. Please try again.</span>
                        `);
                    }
                });
            }

            // Form submission validation
            $('#reservationForm').submit(async function (e) {
                e.preventDefault();
                $('.trailer-length-validation').remove();

                const selectedSiteTypes = $('.site-type-checkbox:checked').map(function () {
                    return parseInt($(this).val());
                }).get();
                const trailerLength = $('#trailerLength').val();
                const hasRvChecked = selectedSiteTypes.some(id => rvSiteTypeIds.includes(id));
                const hasTentOnlyChecked = selectedSiteTypes.length === 1 && selectedSiteTypes.includes(tentSiteTypeId);
                const showHandicapped = $('#showHandicapped').is(':checked');
                const siteId = $('#chosenSiteId').val();
                let selectedSite = siteId ? Object.values(window.siteData).find(s => s.siteId.toString() === siteId.toString()) : null;

                if (!siteId) {
                    Swal.fire({
                        icon: 'error',
                        title: 'No Site Selected',
                        text: 'Please select a campsite.',
                    });
                    return false;
                }

                // Check if trailer length is required
                const needsTrailerLength = (hasRvChecked || (selectedSiteTypes.length === 0 && showHandicapped)) && !hasTentOnlyChecked;
                if (needsTrailerLength && !trailerLength) {
                    $('#trailerLengthSection .col-8').append(
                        '<div class="trailer-length-validation text-danger mt-1"><small>Please enter trailer length for RV sites</small></div>'
                    );
                    return false;
                }

                if (!selectedSite) {
                    try {
                        console.log('Fetching site details for siteId:', siteId);
                        const response = await $.ajax({
                            url: `/api/Reservation/GetSiteDetails?siteId=${encodeURIComponent(siteId)}`,
                            method: 'GET',
                            dataType: 'json'
                        });
                        if (response) {
                            selectedSite = {
                                siteId: response.siteId.toString(),
                                name: response.name,
                                trailerMaxSize: response.trailerMaxSize,
                                siteType: response.siteTypeName,
                                siteTypeId: response.siteTypeId,
                                pricePerDay: response.pricePerDay,
                                isHandicappedAccessible: response.isHandicappedAccessible || false
                            };
                            window.siteData[response.name] = selectedSite;
                            console.log('Fetched site details:', selectedSite);
                        }
                    } catch (error) {
                        console.error('Error fetching site details:', error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Site Data Error',
                            text: 'Unable to fetch site details. Please try again.',
                        });
                        return false;
                    }
                }

                if (!selectedSite) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Site Data Error',
                        text: 'Selected site data not found. Please try again.',
                    });
                    return false;
                }

                const isTentSiteSelected = selectedSite && (selectedSite.siteTypeId === 4 || selectedSite.siteType === 'Tent/Overflow');

                if (hasRvChecked && !trailerLength && !isTentSiteSelected) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Missing Trailer Length',
                        text: 'Please enter a trailer length for RV sites.',
                    });
                    return false;
                }

                // Validate trailer length against site max
                if (trailerLength && selectedSite.trailerMaxSize && parseFloat(trailerLength) > selectedSite.trailerMaxSize) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid Trailer Length',
                        text: `Trailer length (${trailerLength} ft) exceeds site maximum (${selectedSite.trailerMaxSize} ft).`,
                    });
                    return false;
                }

                // Check if the selected site is handicapped-accessible and show SweetAlert
                if (selectedSite.isHandicappedAccessible) {
                    const result = await Swal.fire({
                        icon: 'info',
                        title: 'Handicapped-Accessible Site Selected',
                        text: 'You have selected a handicapped-accessible site. Please confirm you require this accommodation.',
                        showCancelButton: true,
                        confirmButtonText: 'Confirm',
                        cancelButtonText: 'Select Another Site'
                    });

                    if (!result.isConfirmed) {
                        console.log('User cancelled handicapped site confirmation');
                        return false;
                    }
                    console.log('User confirmed handicapped site, submitting form');
                } else {
                    console.log('Non-handicapped site selected, submitting form');
                }


                 //Sweet alert for PCS
                if(updatePCSMessage()){
                    console.log(`Showing PCS message`);
                    $('#PCSMessage').show();
                    const result = await Swal.fire({
                            icon: 'info',
                            title: 'PCS Orders Required',
                            text: 'The reservation is over 180 days. The customer will need to provide proof of PCS orders. Please confirm that they intend to stay this long and that they will provide the appropriate documentation.',
                            showCancelButton: true,
                            confirmButtonText: 'Confirm',
                            cancelButtonText: 'Change Dates'
                        });
                    if (!result.isConfirmed) {
                        console.log('User cancelled PCS confirmation');
                        return;
                    }
                    console.log('User confirmed PCS orders, submitting form');
                } else {
                    console.log('PCS orders not required, submitting form');
                    console.log(`Hiding PCS message`);
                    $('#PCSMessage').hide();
                }


                // Submit the form
                $(this).off('submit').submit();
            });

            // Cancel Reservation button
            $('#cancelReservation').click(function () {
                Swal.fire({
                    title: 'Are you sure?',
                    text: 'Do you want to cancel this reservation? This action cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, cancel it!',
                    cancelButtonText: 'No, keep it'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('<input>').attr({
                            type: 'hidden',
                            name: 'cancelReservation',
                            value: 'true'
                        }).appendTo('#reservationForm');
                        $('#reservationForm').submit();
                    }
                });
            });

            // Handle SVG map site selection
            window.onSiteSelected = function (siteId) {
                console.log('onSiteSelected called with siteId:', siteId); // Debugging
                if (siteId && $('#chosenSiteId').val() !== siteId && !isProgrammaticChange) {
                    isProgrammaticChange = true;
                    $('#chosenSiteId').val(siteId).trigger('change'); // Trigger chosen site change
                    updateCurrentSiteDisplay(siteId);
                }
            };

            // Modal event handlers
            $('#siteMapModal').on('shown.bs.modal', function () {
                if (!window.siteMapInitialized) {
                    console.log('Initializing SVG map');
                    loadSvgMap();
                    window.siteMapInitialized = true;
                } else if (Object.keys(window.siteData).length > 0) {
                    console.log('Updating map with existing siteData');
                    updateMap(Object.values(window.siteData), parseFloat($('#trailerLength').val()) || 0);
                    const siteId = $('#chosenSiteId').val();
                    if (siteId) {
                        updateHandicappedMessage(siteId);
                    }
                }
            });

            $('#siteMapModal').on('hidden.bs.modal', function () {
                console.log('Modal hidden, resetting siteMapInitialized');
                window.siteMapInitialized = false;
                const selectedSiteId = $('#chosenSiteId').val();
                if (selectedSiteId) {
                    console.log(`Retaining selected siteId: ${selectedSiteId}`);
                    updateHandicappedMessage(selectedSiteId);
                } else {
                    console.log('No site selected, hiding handicapped message');
                    $('#handicappedMessage').hide();
                }
            });

            // Initialize site type prices and data
            window.siteData = window.siteData || {};

            // Form validation
            function validateForm() {
                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();
                const selectedSiteTypes = $('.site-type-checkbox:checked').length;
                const trailerLength = $('#trailerLength').val();
                const hasRvChecked = $('.site-type-checkbox:checked').toArray()
                    .some(cb => rvSiteTypeIds.includes(parseInt($(cb).val())));
                const hasTentChecked = $('#siteType_4').is(':checked');
                const showHandicapped = $('#showHandicapped').is(':checked');
                const siteId = $('#chosenSiteId').val();

                const hasValidSiteSelection = selectedSiteTypes > 0 || showHandicapped;
                const isValid = startDate && endDate && hasValidSiteSelection;

                const siteNote = ($('#selectSiteNote').text() == '')

                $('#findAvailableSites').prop('disabled', !isValid);
                $('#saveChanges').prop('disabled', !isValid || !siteId || !changesMade || !siteNote);

                console.log('Validation:', {
                    startDate: !!startDate,
                    endDate: !!endDate,
                    selectedSiteTypes,
                    showHandicapped,
                    hasValidSiteSelection,
                    hasRvChecked,
                    trailerLength: !!trailerLength,
                    hasTentChecked,
                    isValid
                });

                updateValidationMessages();
            }

            // Continue button handler
            $('#continueButton').click(async function(e) {
                e.preventDefault();

                const siteId = $('#chosenSiteId').val();
                if(!siteId){
                    console.warn("No siteId found in #chosenSiteId");
                    Swal.fire({
                        icon: 'warning',
                        title: 'No Site Selected',
                        text: 'Please select a site before continuing.'
                    });
                    return;
                }

                let selectedSite = Object.values(window.siteData).find(s => s.siteId.toString() === siteId.toString());
                if (!selectedSite) {
                    try {
                        console.log('Fetching site details for siteId:', siteId);
                        const response = await $.ajax({
                            url: `/api/Reservation/GetSiteDetails?siteId=${encodeURIComponent(siteId)}`,
                            method: 'GET',
                            dataType: 'json'
                        });
                        if (response) {
                            selectedSite = {
                                siteId: response.siteId.toString(),
                                name: response.name,
                                description: response.description,
                                trailerMaxSize: response.trailerMaxSize,
                                siteTypeId: response.siteTypeId,
                                siteType: response.siteTypeName,
                                pricePerDay: response.pricePerDay,
                                isHandicappedAccessible: response.isHandicappedAccessible || false
                            };
                            window.siteData[response.name] = selectedSite;
                            console.log('Fetched site details:', selectedSite);
                        }
                    } catch (error) {
                        console.error('Error fetching site details:', error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Site Data Error',
                            text: 'Unable to fetch site details. Please try again.',
                        });
                        return;
                    }
                }

                if (!selectedSite) {
                    console.error('Selected site data not found for siteId:', siteId);
                    Swal.fire({
                        icon: 'error',
                        title: 'Site Data Error',
                        text: 'Selected site data not found. Please try again.',
                    });
                    return;
                }

                // Always show SweetAlert for handicapped sites
                if (selectedSite.isHandicappedAccessible) {
                    const result = await Swal.fire({
                        icon: 'info',
                        title: 'Handicapped-Accessible Site Selected',
                        text: 'You have selected a handicapped-accessible site. Please confirm you require this accommodation.',
                        showCancelButton: true,
                        confirmButtonText: 'Confirm',
                        cancelButtonText: 'Select Another Site'
                    });

                    if (!result.isConfirmed) {
                        console.log('User cancelled handicapped site confirmation');
                        return;
                    }
                    console.log('User confirmed handicapped site, submitting form');
                } else {
                    console.log('Non-handicapped site selected, submitting form');
                }
            });
        });

        function updateVehiclePlateFields() {
            const count = parseInt($('#NumberOfVehicles').val()) || 0;

            $('#vehiclePlate1Wrapper').toggle(count >= 1);
            $('#vehiclePlate2Wrapper').toggle(count >= 2);
            $('#vehiclePlate3Wrapper').toggle(count >= 3);

            if (platesFromServer && platesFromServer.length > 0) {
                if (count >= 1) $('input[name="VehiclePlate1"]').val(platesFromServer[0] || "");
                if (count >= 2) $('input[name="VehiclePlate2"]').val(platesFromServer[1] || "");
                if (count >= 3) $('input[name="VehiclePlate3"]').val(platesFromServer[2] || "");
            }
        }

        function updateVehicleLimits() {
            const selectedIds = $('.site-type-checkbox:checked').map(function () {
                return parseInt($(this).val());
            }).get();

            if (selectedIds.includes(4)) {
                $('#vehicleSection').hide();
                $('#NumberOfVehicles').val("1");
                $('#vehiclePlate1Wrapper, #vehiclePlate2Wrapper, #vehiclePlate3Wrapper').hide();
                return;
            }

            $('#vehicleSection').show();

            const hasPremium = selectedIds.includes(1) || selectedIds.includes(2);
            const hasNonPremiumRv = selectedIds.includes(3) || selectedIds.includes(7);

            let max = 2;
            if (hasPremium && !hasNonPremiumRv) {
                max = 3;
            }

            let current = parseInt($('#NumberOfVehicles').val());
            if (current > max) {
                $('#NumberOfVehicles').val(max);
            }

            $('#NumberOfVehicles option').each(function () {
                let val = parseInt($(this).val());
                $(this).prop('disabled', val > max);
            });

            updateVehiclePlateFields();
        }

        $('#NumberOfVehicles').on('change', updateVehiclePlateFields);

    </script>
}