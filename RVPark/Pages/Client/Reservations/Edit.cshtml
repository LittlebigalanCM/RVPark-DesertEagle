                    //Update the current site display
            async function updateCurrentSiteDisplay(siteId) {
                if (siteId) {
                    // Try to get site name from siteData first
                    let siteName = null;
                    const site = Object.values(window.siteData || {}).find(s => s.siteId.toString() === siteId.toString());

                    if (site) {
                        siteName = site.name;
                    } else {
                        // If not in siteData, fetch from server
                        try {
                            const response = await $.ajax({
                                url: `/api/Reservation/GetSiteDetails?siteId=${encodeURIComponent(siteId)}`,
                                method: 'GET',
                                dataType: 'json'
                            });
                            if (response && response.name) {
                                siteName = response.name;
                            }
                        } catch (error) {
                            console.error('Error fetching site name:', error);
                        }
                    }

                    $('#currentSite').val(siteName ? `Current Site: ${siteName}` : `Current Site: ${siteId}`);
                } else {
                    $('#currentSite').val('Current Site: None');
                }
            }

            // Site change handler
            $('#chosenSiteId').change(function () {
                if (isProgrammaticChange) {
                    console.log('Programmatic change detected, resetting isProgrammaticChange');
                    isProgrammaticChange = false;
                    return;
                }
                const siteId = $(this).val();
                updateCurrentSiteDisplay(siteId);
                console.log('chosen site changed to siteId:', siteId);
                if (siteId) {
                    if (!window.siteMapSelectionInProgress) {
                        setTimeout(() => {
                            if (window.selectSiteOnMapById) {
                                console.log('Calling selectSiteOnMapById with:', siteId);
                                window.siteMapSelectionInProgress = true;
                                window.selectSiteOnMapById(siteId);
                                window.siteMapSelectionInProgress = false;
                            } else {
                                console.warn('selectSiteOnMapById not defined');
                            }
                        }, 200);
                    }
                } else {
                    console.log('No site selected, hiding siteInfo');
                    $('#siteInfo').hide();
                    $('#handicappedMessage').hide();
                }

                $('#selectSiteNote').text('');
                setCurrentSiteDisplay(siteId);

                checkForChanges();
                calculateFeeChanges();
                checkAvailability();
                validateForm();
            });

            // Find Available Sites button click
                $('#findAvailableSites').click(function () {
                    const userId = $('#Reservation_UserId').val();
                    const startDate = $('#startDate').val();
                    const endDate = $('#endDate').val();
                    const selectedSiteTypes = $('.site-type-checkbox:checked').map(function () {
                        return parseInt($(this).val());
                    }).get();
                    const hasRvChecked = selectedSiteTypes.some(id => rvSiteTypeIds.includes(id));
                    const trailerLength = hasRvChecked ? ($('#trailerLength').val() || "") : "";

                    if (!userId || !startDate || !endDate) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Missing Fields',
                            text: 'Please fill in all required fields.',
                        });
                        return;
                    }

                    if (selectedSiteTypes.length === 0) {
                        Swal.fire({
                            icon: 'error',
                            title: 'No Site Type Selected',
                            text: 'Please select at least one site type.',
                        });
