@page
@model RVPark.Pages.Client.Reservations.IndexModel
@{
    ViewData["Title"] = "My Reservations";
}

<div class="pt-4 text-center">
    <a asp-page="Browse" asp-route-id="0" class="btn btn-primary">
        <i class="fas fa-plus"></i> &nbsp;Make Reservation
    </a>
    <a asp-page="ReservationHistory" class="btn btn-secondary">
        Reservation History
    </a>
</div>

<div class="pt-4 pb-2 text-center">
    <h2 class="text-secondary">Current Reservation(s)</h2>
</div>

<div class="container pt-3">
    <table id="DT_Current" class="table table-striped table-bordered" style="width:100%">
        <thead>
            <tr class="table-secondary">
                <th>Reservation Number</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Site Name</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <!-- Table will be populated by DataTables -->

        </tbody>
    </table>
</div>


