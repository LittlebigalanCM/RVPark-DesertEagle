@page "{reservationId:int}"
@model RVPark.Pages.Client.Reservations.UploadDocumentModel
@{
    ViewData["Title"] = "Upload Document";

}

@* //I'll be honest: This is AI generated and I have no clue if it works.
//I just wanted something to possibly be able to handle fileuploads while I do work with confirming the reservations...
//but I haven't been able to test it at all. Feel free to use this or ditch it *@


<div class="container">
    <div class="row px-2 mx-2 backgroundWhite border">
        <div class="col-12 px-3" style="border-bottom:1px solid #325d88">
            <h2 class="text-primary">File Upload</h2>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <div class="col-8">
            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="ReservationId" />
                <input type="hidden" asp-for="DocType" />

                <div class="mb-3">
                    <label class="form-label">Upload PCS Orders (PDF / image)</label>
                    <input asp-for="DocumentFile" type="file" class="form-control" accept=".pdf,image/*" />
                    <span asp-validation-for="DocumentFile" class="text-danger"></span>
                </div>

                <div class="mb-3 text-muted">
                    Allowed types: PDF, JPG, PNG. Max size: 10 MB.
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Upload</button>
                    <a asp-page="/Client/Reservations/Index" class="btn btn-secondary">My Reservations</a>
                    <a asp-page="/Client/Reservations/Receipt" asp-route-reservationId="@Model.ReservationId" class="btn btn-outline-secondary">View Reservation</a>
                </div>
            </form>
        </div>
    </div>
</div>