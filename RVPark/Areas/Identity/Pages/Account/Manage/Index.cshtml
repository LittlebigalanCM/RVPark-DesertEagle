@page
@model IndexModel
@using Infrastructure.Utilities
@{
    ViewData["Title"] = "My Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h1 class="text-center">@ViewData["Title"]</h1>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row justify-content-center">
    <div class="col-md-8">
        <hr />
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control" placeholder="Username" disabled />
                <label asp-for="Username" class="form-label"></label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.FirstName" class="form-control" placeholder="First Name" />
                <label asp-for="Input.FirstName" class="form-label"></label>
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.LastName" class="form-control" placeholder="Last Name" />
                <label asp-for="Input.LastName" class="form-label"></label>
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Phone Number" />
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>
            <div class="py-2">
                <div class="col-9">
                    @Html.DropDownListFor(m => m.Input.SelectedStatusId, Model.MilitaryStatusesList, " - Please select a Military Status - ", new { @class = "form-control selectpicker", @id = "ddlStatuses", data_live_search = "true" })
                </div>
                <span asp-validation-for="Input.SelectedStatusId" class="text-danger"></span>
            </div>
            <div class="py-2" id="branchWrapper" style="display:none;">
                <div class="col-9">
                    @Html.DropDownListFor(m => m.Input.SelectedBranchId, Model.MilitaryBranchesList, " - Please select a Military Branch - ", new { @class = "form-control selectpicker", @id = "ddlBranches", data_live_search = "true" })
                </div>
                <span asp-validation-for="Input.SelectedBranchId" class="text-danger"></span>
            </div>
            <div class="py-2" id="rankWrapper" style="display:none;">
                <div class="col-9">
                    @Html.DropDownListFor(m => m.Input.SelectedRankId, Model.MilitaryRanksList, " - Please select a Military Rank - ", new { @class = "form-control selectpicker", @id = "ddlRanks", data_live_search = "true" })
                </div>
                <span asp-validation-for="Input.SelectedRankId" class="text-danger"></span>
            </div>
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Save</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
	<script>
		$(function () {
		  const $status = $("#ddlStatuses");
		  const $branchWrap = $("#branchWrapper");
		  const $rankWrap = $("#rankWrapper");

		  function toggleDropdowns() {
			const txt = ($status.find("option:selected").text() || "").toLowerCase();
			const isCivilian = txt.indexOf("civilian") !== -1;

			$branchWrap.toggle(!isCivilian);
            $rankWrap.toggle(!isCivilian);
		  }

		  $status.on("change", toggleDropdowns);
		  toggleDropdowns();
		});
	</script>
}
